---
const navItems = [
  { label: "ムラッシュFCとは", href: "/about" },
  { label: "選手名鑑", href: "/players" },
  { label: "大会の軌跡", href: "/tournaments" },
  { label: "再スタート編", href: "/rebirth" },
  { label: "歴史・年表", href: "/history" },
  { label: "用語辞典", href: "/glossary" },
  { label: "ブログ", href: "/blog" },
];

const pathname = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? pathname === "/" : pathname.startsWith(href);
---

<header
  class="sticky top-0 z-50 border-b border-white/10 bg-murash-black/80 backdrop-blur supports-[backdrop-filter]:bg-murash-black/60"
>
  <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-4 sm:px-6">
    <!-- ロゴ -->
    <a href="/" class="group flex items-center gap-2">
      <span
        class="flex h-9 w-9 items-center justify-center rounded-sm bg-murash-red font-display text-lg font-bold text-white"
        >M</span
      >
      <span class="font-display text-lg font-bold tracking-wide text-white">
        MURASH FC
        <span class="block text-[10px] font-normal tracking-widest text-white/40"
          >FAN SITE / 非公認</span
        >
      </span>
    </a>

    <!-- PCナビ -->
    <nav class="hidden items-center gap-1 lg:flex">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class:list={[
              "relative px-3 py-2 text-sm font-medium transition-colors hover:text-white",
              isActive(item.href) ? "text-white" : "text-white/60",
            ]}
          >
            {item.label}
            {isActive(item.href) && (
              <span class="absolute inset-x-3 -bottom-px h-0.5 bg-murash-red" />
            )}
          </a>
        ))
      }
    </nav>

    <!-- モバイルメニューボタン -->
    <button
      id="menu-toggle"
      type="button"
      class="inline-flex items-center justify-center rounded-sm p-2 text-white/80 hover:bg-white/5 hover:text-white lg:hidden"
      aria-label="メニューを開く"
      aria-expanded="false"
    >
      <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>

  <!-- モバイルナビ -->
  <nav id="mobile-nav" class="hidden border-t border-white/10 bg-murash-charcoal lg:hidden">
    <ul class="space-y-1 px-4 py-3">
      {
        navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class:list={[
                "block rounded-sm px-3 py-2.5 text-sm font-medium transition-colors",
                isActive(item.href)
                  ? "bg-murash-red/10 text-murash-red"
                  : "text-white/70 hover:bg-white/5 hover:text-white",
              ]}
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>

<script>
  const toggle = document.getElementById("menu-toggle");
  const nav = document.getElementById("mobile-nav");
  toggle?.addEventListener("click", () => {
    const open = nav?.classList.toggle("hidden") === false;
    toggle.setAttribute("aria-expanded", String(open));
  });
</script>
