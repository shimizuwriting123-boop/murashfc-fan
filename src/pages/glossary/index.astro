---
import Layout from "../../layouts/Layout.astro";

interface Term {
  id: string;
  term: string;
  definition: string;
}

interface Category {
  id: string;
  icon: string;
  title: string;
  terms: Term[];
}

const categories: Category[] = [
  {
    id: "positions",
    icon: "🎯",
    title: "ポジション・役割",
    terms: [
      {
        id: "president",
        term: "プレジデント",
        definition:
          "チームのオーナー兼顔役。ムラッシュFCでは加藤純一が務める。試合中にPKを蹴る特権を持つ。",
      },
      {
        id: "chairman",
        term: "チェアマン",
        definition: "キングスリーグ全体のトップ。元スペイン代表DFジェラール・ピケが務める。",
      },
      {
        id: "coach",
        term: "コーチ",
        definition: "試合前にシークレットカードを引く役割を担う。",
      },
    ],
  },
  {
    id: "match-basics",
    icon: "⚽",
    title: "試合の基本",
    terms: [
      {
        id: "seven-a-side",
        term: "7人制サッカー",
        definition: "通常11人のサッカーと違い、GK含む7人で戦う。",
      },
      {
        id: "forty-min",
        term: "40分制",
        definition: "前半20分・後半20分の計40分。引き分けはなし。",
      },
      {
        id: "one-on-one-start",
        term: "1対1スタート",
        definition:
          "試合開始時は1対1＋GKの計4人。1分ごとに1人ずつ追加され、5分で7対7に。",
      },
      {
        id: "drop-ball",
        term: "ドロップボール",
        definition:
          "センターサークル上5mのケージからボールが落とされて試合開始。ゴールラインで待機した選手がブザーで争奪戦を開始する。",
      },
      {
        id: "double-goal-time",
        term: "ダブルゴールタイム",
        definition: "前半17〜20分の3分間。ゴールが2倍にカウントされる特別ボールが投入される。",
      },
      {
        id: "dice-time",
        term: "サイコロタイム",
        definition: "後半開始前にスタンドから巨大サイコロを振り、出た目で後半開始時の人数が決まる。",
      },
      {
        id: "match-ball",
        term: "マッチボール",
        definition: "終盤4分間。5対5から1分ごとに1人ずつ退場していくサバイバル形式。",
      },
      {
        id: "golden-goal",
        term: "ゴールデンゴール",
        definition: "マッチボール中に同点に追いついた場合、先にゴールを決めた側が勝つ方式。",
      },
    ],
  },
  {
    id: "secret-cards",
    icon: "🃏",
    title: "シークレットカード（全7種）",
    terms: [
      {
        id: "card-double-goal",
        term: "ダブルゴール（GOAL×2）",
        definition: "4分間ゴールが2倍。",
      },
      {
        id: "card-suspension",
        term: "出場停止（SUSPENSION）",
        definition: "4分間相手チームから1人退場（GK除く）。",
      },
      {
        id: "card-penalty",
        term: "ペナルティキック（PENALTY）",
        definition: "流れ無視でPK1本獲得。",
      },
      {
        id: "card-shootout",
        term: "シュートアウト（SHOOT OUT）",
        definition: "5秒間のフィールドプレイヤーvsGKの1対1。",
      },
      {
        id: "card-star-player",
        term: "スタープレイヤー（STAR PLAYER）",
        definition: "選んだ選手のゴールが2倍に。該当選手はアームバンドを着用。",
      },
      {
        id: "card-joker",
        term: "ジョーカー（JOKER）",
        definition: "好きなカードを発動 or 相手のカードを奪う、のどちらかを選択。",
      },
      {
        id: "card-reverse-penalty",
        term: "リバースペナルティ（REVERSE PENALTY）",
        definition:
          "2025年10月追加の新カード。相手にPKを蹴らせる。決まっても得点にならないが、外せば自チームに加点。",
      },
    ],
  },
  {
    id: "special-pk",
    icon: "🎯",
    title: "特殊PK",
    terms: [
      {
        id: "president-penalty",
        term: "プレジデントペナルティ",
        definition:
          "1試合1回、5〜17分または23〜36分の間にプレジデントが自らPKを蹴れる。",
      },
      {
        id: "shootout-pk",
        term: "シュートアウト",
        definition:
          "プレジデント不在時のPK代用。フィールドプレイヤーが5秒以内にドリブルしてシュート。",
      },
    ],
  },
  {
    id: "fouls",
    icon: "🟨",
    title: "反則・カード",
    terms: [
      {
        id: "yellow-card",
        term: "イエローカード",
        definition: "2分間の出場停止（時限退場）。",
      },
      {
        id: "red-card",
        term: "レッドカード",
        definition: "退場処分。5分後に別の選手が参加可能（完全退場ではない）。",
      },
      {
        id: "no-sliding-tackle",
        term: "スライディングタックル禁止",
        definition:
          "基本禁止。ただしGKがペナルティエリア内で使う、ボールをブロックするなどの目的は例外。",
      },
      {
        id: "var",
        term: "VAR（リクエスト制）",
        definition: "審判団に自ら要求する制度。1試合1回まで。",
      },
    ],
  },
  {
    id: "tournament-formats",
    icon: "🏆",
    title: "大会形式",
    terms: [
      {
        id: "kwc",
        term: "キングスワールドカップ（KWC）",
        definition: "キングスリーグの世界大会。",
      },
      {
        id: "nations",
        term: "ネーションズ",
        definition: "国別対抗戦形式の世界大会（イタリア2025・ブラジル2026）。",
      },
      {
        id: "clubs",
        term: "クラブズ",
        definition: "クラブ対抗戦形式の世界大会（フランス2025）。",
      },
      {
        id: "last-chance-round",
        term: "ラストチャンスラウンド",
        definition: "グループステージ敗退チームの敗者復活戦。",
      },
      {
        id: "swiss",
        term: "スイス方式",
        definition: "勝者同士・敗者同士で対戦を組む方式。",
      },
    ],
  },
  {
    id: "murashfc-related",
    icon: "🇯🇵",
    title: "ムラッシュFC関連",
    terms: [
      {
        id: "murashfc",
        term: "ムラッシュFC（MURASH FC）",
        definition: "加藤純一がオーナーを務める日本のキングスリーグチーム。",
      },
      {
        id: "permanent-team",
        term: "常設チーム",
        definition: "2025年11月発足。大会ごとの招集ではなく定期的に活動するクラブ体制。",
      },
      {
        id: "tryout",
        term: "トライアウト",
        definition: "常設メンバー選考のための選考会。書類選考から最終セレクションまで複数段階。",
      },
      {
        id: "society-football",
        term: "ソサイチ",
        definition:
          "ブラジル発祥の7人制サッカー。キングスリーグのルールのベースで、ムラッシュFCメンバーにもソサイチ日本代表経験者が多い。",
      },
    ],
  },
  {
    id: "media",
    icon: "📺",
    title: "配信・メディア",
    terms: [
      {
        id: "abema",
        term: "ABEMA",
        definition:
          "日本でのキングスW杯公式配信プラットフォーム。第4回ブラジル大会で特集を組み、生配信も実施して知名度向上に大きく貢献した。",
      },
      {
        id: "twitch",
        term: "Twitch",
        definition: "加藤純一が試合中継で使う配信プラットフォーム。世界的にもキングスリーグ公式配信先。",
      },
    ],
  },
];
---

<Layout
  title="用語辞典 | ムラッシュFC ファンサイト（非公認）"
  description="キングスリーグとムラッシュFCを楽しむための用語をまとめた用語辞典。ポジション・試合ルール・シークレットカード・大会形式などを2026年最新ルール対応で解説します。"
>
  <!-- ページヘッダー -->
  <section class="relative overflow-hidden border-b border-white/10">
    <div class="absolute inset-0 -z-10">
      <div class="absolute inset-0 bg-gradient-to-br from-murash-charcoal via-murash-black to-black"></div>
      <div class="absolute -right-24 -top-24 h-72 w-72 rounded-full bg-murash-red/20 blur-3xl"></div>
    </div>

    <div class="mx-auto max-w-4xl px-4 py-16 sm:px-6">
      <p class="font-display text-sm font-semibold tracking-[0.3em] text-murash-red">GLOSSARY</p>
      <h1 class="mt-3 font-display text-4xl font-bold tracking-tight text-white sm:text-5xl">
        用語辞典
      </h1>
      <p class="mt-4 text-sm leading-relaxed text-white/60 sm:text-base">
        キングスリーグとムラッシュFCを楽しむための用語をまとめました。2026年最新ルール対応。
      </p>

      <!-- 目次 -->
      <nav class="mt-8 flex flex-wrap gap-2" aria-label="カテゴリ目次">
        {
          categories.map((c) => (
            <a
              href={`#${c.id}`}
              class="inline-flex items-center gap-1.5 rounded-sm border border-white/10 bg-white/5 px-3 py-1.5 text-xs font-semibold text-white/70 transition-colors hover:border-murash-red/40 hover:text-white"
            >
              <span aria-hidden="true">{c.icon}</span>
              {c.title}
            </a>
          ))
        }
      </nav>
    </div>
  </section>

  <!-- 用語一覧 -->
  <div class="mx-auto max-w-4xl px-4 py-16 sm:px-6">
    <div class="space-y-14">
      {
        categories.map((cat) => (
          <section id={cat.id} class="scroll-mt-24">
            <h2 class="flex items-center gap-3 font-display text-2xl font-bold tracking-tight text-white sm:text-3xl">
              <span aria-hidden="true">{cat.icon}</span>
              {cat.title}
              <span class="font-display text-sm font-semibold text-white/30">
                {cat.terms.length}
              </span>
            </h2>
            <div class="mt-2 h-px w-full bg-gradient-to-r from-murash-red/60 to-transparent" />

            <dl class="mt-5 grid gap-3 sm:grid-cols-2">
              {cat.terms.map((t) => (
                <div
                  id={t.id}
                  class="scroll-mt-24 rounded-md border border-white/10 bg-murash-charcoal p-4 transition-colors hover:border-murash-red/40 sm:p-5"
                >
                  <dt class="font-display text-base font-bold sm:text-lg">
                    <a
                      href={`#${t.id}`}
                      class="text-white transition-colors hover:text-murash-red"
                    >
                      {t.term}
                    </a>
                  </dt>
                  <dd class="mt-1.5 text-sm leading-[1.8] text-[#e5e5e5]">{t.definition}</dd>
                </div>
              ))}
            </dl>
          </section>
        ))
      }
    </div>

    <!-- 注意書き -->
    <div class="mt-14 rounded-md border border-white/10 bg-white/5 p-4">
      <p class="text-xs leading-relaxed text-white/50">
        ※キングスリーグのルールは頻繁に改変されています。本記事は2026年1月時点の情報を基にしています。
      </p>
    </div>
  </div>
</Layout>
