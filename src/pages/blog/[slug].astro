---
import Layout from "../../layouts/Layout.astro";
import { getCollection, render, type CollectionEntry } from "astro:content";

export async function getStaticPaths() {
  const posts = (await getCollection("blog")).sort(
    (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
  );
  return posts.map((post, i) => ({
    params: { slug: post.id },
    props: {
      post,
      // 新しい順に並んでいるので、newer = 1つ前 / older = 1つ後
      newer: posts[i - 1] ?? null,
      older: posts[i + 1] ?? null,
    },
  }));
}

interface Props {
  post: CollectionEntry<"blog">;
  newer: CollectionEntry<"blog"> | null;
  older: CollectionEntry<"blog"> | null;
}

const { post, newer, older } = Astro.props;
const { Content } = await render(post);

const fmtDate = (d: Date) =>
  `${d.getUTCFullYear()}.${String(d.getUTCMonth() + 1).padStart(2, "0")}.${String(
    d.getUTCDate(),
  ).padStart(2, "0")}`;
---

<Layout
  title={`${post.data.title} | ブログ | ムラッシュFC ファンサイト（非公認）`}
  description={`${post.data.title}（${post.data.category}）｜ムラッシュFC ファンサイト 管理人ブログ`}
>
  <!-- 記事ヘッダー -->
  <section class="relative overflow-hidden border-b border-white/10">
    <div class="absolute inset-0 -z-10">
      <div class="absolute inset-0 bg-gradient-to-br from-murash-charcoal via-murash-black to-black"></div>
      <div class="absolute -right-20 -top-24 h-72 w-72 rounded-full bg-murash-red/20 blur-3xl"></div>
    </div>

    <div class="mx-auto max-w-3xl px-4 py-14 sm:px-6 sm:py-16">
      <a
        href="/blog"
        class="inline-flex items-center gap-1.5 text-sm text-white/50 transition-colors hover:text-white"
      >
        <span aria-hidden="true">←</span> ブログ一覧へ戻る
      </a>

      <div class="mt-8 flex flex-wrap items-center gap-x-3 gap-y-1">
        <span class="rounded-sm border border-murash-red/40 bg-murash-red/10 px-2 py-0.5 font-display text-xs font-semibold tracking-wide text-murash-red">
          {post.data.category}
        </span>
        <time class="font-display text-xs font-semibold tracking-wider text-white/40">
          {fmtDate(post.data.date)}
        </time>
      </div>

      <h1 class="mt-4 font-display text-3xl font-bold leading-tight tracking-tight text-white sm:text-4xl">
        {post.data.title}
      </h1>
    </div>
  </section>

  <!-- 本文 -->
  <div class="mx-auto max-w-3xl px-4 py-14 sm:px-6">
    <article class="article-body">
      <Content />
    </article>

    <!-- 前後の記事ナビ -->
    <nav class="mt-16 grid gap-3 border-t border-white/10 pt-8 sm:grid-cols-2">
      {
        older ? (
          <a
            href={`/blog/${older.id}`}
            class="group rounded-md border border-white/10 bg-murash-charcoal p-4 transition-colors hover:border-murash-red/50"
          >
            <span class="font-display text-xs font-semibold tracking-wider text-white/40">
              ← 古い記事
            </span>
            <p class="mt-1.5 font-display text-sm font-bold text-white transition-colors group-hover:text-murash-red">
              {older.data.title}
            </p>
          </a>
        ) : (
          <span class="hidden sm:block" />
        )
      }
      {
        newer ? (
          <a
            href={`/blog/${newer.id}`}
            class="group rounded-md border border-white/10 bg-murash-charcoal p-4 text-right transition-colors hover:border-murash-red/50"
          >
            <span class="font-display text-xs font-semibold tracking-wider text-white/40">
              新しい記事 →
            </span>
            <p class="mt-1.5 font-display text-sm font-bold text-white transition-colors group-hover:text-murash-red">
              {newer.data.title}
            </p>
          </a>
        ) : (
          <span class="hidden sm:block" />
        )
      }
    </nav>

    <div class="mt-10">
      <a
        href="/blog"
        class="inline-flex items-center gap-2 rounded-sm border border-white/20 px-6 py-3 font-display text-sm font-semibold tracking-wide text-white transition-colors hover:border-white/40 hover:bg-white/5"
      >
        <span aria-hidden="true">←</span> ブログ一覧へ戻る
      </a>
    </div>
  </div>
</Layout>

<style is:global>
  .article-body {
    color: #e5e5e5;
  }
  .article-body p {
    margin: 1.4rem 0;
    line-height: 1.95;
    font-size: 1rem;
  }
  .article-body h2 {
    margin: 2.5rem 0 1rem;
    font-size: 1.5rem;
    font-weight: 700;
    color: #fff;
    letter-spacing: -0.01em;
  }
  .article-body h3 {
    margin: 2rem 0 0.75rem;
    font-size: 1.25rem;
    font-weight: 700;
    color: #fff;
  }
  .article-body a {
    color: #e60012;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .article-body a:hover {
    color: #b3000e;
  }
  .article-body ul,
  .article-body ol {
    margin: 1.4rem 0;
    padding-left: 1.5rem;
  }
  .article-body ul {
    list-style: disc;
  }
  .article-body ol {
    list-style: decimal;
  }
  .article-body li {
    margin: 0.5rem 0;
    line-height: 1.85;
  }
  .article-body li::marker {
    color: #e60012;
  }
  .article-body strong {
    color: #fff;
    font-weight: 700;
  }
  .article-body blockquote {
    margin: 1.75rem 0;
    border-left: 3px solid rgba(230, 0, 18, 0.5);
    padding: 0.25rem 0 0.25rem 1.1rem;
    color: rgba(255, 255, 255, 0.6);
  }
  .article-body code {
    background: rgba(255, 255, 255, 0.08);
    padding: 0.12em 0.4em;
    border-radius: 3px;
    font-size: 0.9em;
  }
  .article-body img {
    margin: 1.75rem 0;
    border-radius: 0.375rem;
  }
  .article-body hr {
    margin: 2.5rem 0;
    border-color: rgba(255, 255, 255, 0.1);
  }
</style>
