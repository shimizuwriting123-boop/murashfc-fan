---
import Layout from "../../layouts/Layout.astro";
import { tournaments } from "../../data/tournaments";
---

<Layout
  title="大会の軌跡 | ムラッシュFC ファンサイト（非公認）"
  description="ムラッシュFCが戦ってきたキングスリーグ4大会（メキシコ・イタリア・フランス・ブラジル）の結果と名場面、舞台裏のエピソードを時系列でまとめました。"
>
  <!-- ページヘッダー -->
  <section class="relative overflow-hidden border-b border-white/10">
    <div class="absolute inset-0 -z-10">
      <div class="absolute inset-0 bg-gradient-to-br from-murash-charcoal via-murash-black to-black"></div>
      <div class="absolute -right-24 -top-24 h-72 w-72 rounded-full bg-murash-red/20 blur-3xl"></div>
    </div>

    <div class="mx-auto max-w-3xl px-4 py-16 sm:px-6">
      <p class="font-display text-sm font-semibold tracking-[0.3em] text-murash-red">RESULTS</p>
      <h1 class="mt-3 font-display text-4xl font-bold tracking-tight text-white sm:text-5xl">
        大会の軌跡
      </h1>
      <p class="mt-4 text-sm leading-relaxed text-white/60 sm:text-base">
        メキシコ、イタリア、フランス、ブラジル。ムラッシュFCがこれまで挑んだ4つの大会を、結果と名場面、舞台裏のエピソードとともに時系列で振り返ります。
      </p>
    </div>
  </section>

  <!-- タイムライン -->
  <section class="mx-auto max-w-3xl px-4 py-16 sm:px-6">
    <aside class="mb-10 rounded-md border border-white/10 bg-white/5 p-4 sm:p-5">
      <p class="text-xs leading-relaxed text-white/55 sm:text-sm">
        ※各大会の情報は、MURASH FC公式YouTubeチャンネルでの配信内容や各種報道を元にまとめています。事実と異なる場合は修正しますので、運営者までお知らせください。
      </p>
    </aside>

    <div class="relative">
      <!-- 縦のタイムライン軸 -->
      <span
        aria-hidden="true"
        class="pointer-events-none absolute bottom-4 left-4 top-4 w-px -translate-x-1/2 bg-gradient-to-b from-murash-red/60 via-white/15 to-transparent"
      ></span>

      <ol class="space-y-12">
        {
          tournaments.map((t) => {
            const meta = [
              { label: "形態", value: t.format },
              { label: "結果", value: t.result },
              ...(t.record ? [{ label: "戦績", value: t.record }] : []),
              ...(t.champion ? [{ label: "優勝", value: t.champion }] : []),
            ];
            const hasEpisode = (t.episodes && t.episodes.length > 0) || t.feature;
            return (
              <li class="relative pl-12 sm:pl-14">
                {/* タイムラインのドット */}
                <span
                  aria-hidden="true"
                  class="absolute left-4 top-2 flex h-8 w-8 -translate-x-1/2 items-center justify-center rounded-full border border-murash-red/50 bg-murash-black"
                >
                  <span class="h-2.5 w-2.5 rounded-full bg-murash-red" />
                </span>

                <article class="overflow-hidden rounded-md border border-white/10 bg-murash-charcoal">
                  {/* ヘッダー */}
                  <div class="border-b border-white/10 p-5 sm:p-6">
                    <div class="flex flex-wrap items-center gap-x-3 gap-y-1">
                      <span class="rounded-sm bg-murash-red px-2 py-0.5 font-display text-xs font-bold tracking-wide text-white">
                        {t.no}
                      </span>
                      <span class="font-display text-xs font-semibold tracking-wider text-white/40">
                        {t.date}
                      </span>
                    </div>
                    <h2 class="mt-2 font-display text-2xl font-bold tracking-tight text-white sm:text-3xl">
                      {t.name}
                    </h2>

                    <dl class="mt-4 space-y-2 text-sm">
                      {meta.map((m) => (
                        <div class="flex gap-3">
                          <dt class="w-12 shrink-0 pt-0.5 font-display text-xs font-semibold tracking-wider text-white/40">
                            {m.label}
                          </dt>
                          <dd class="leading-relaxed text-[#e5e5e5]">{m.value}</dd>
                        </div>
                      ))}
                    </dl>
                  </div>

                  {/* 本文 */}
                  <div class="space-y-5 p-5 sm:p-6">
                    {/* 見どころ */}
                    <div>
                      <h3 class="flex items-center gap-2 font-display text-sm font-bold tracking-widest text-murash-red">
                        <span class="inline-block h-3 w-1 rounded-full bg-murash-red" />
                        見どころ
                      </h3>
                      <p class="mt-2 text-sm leading-[1.85] text-[#e5e5e5] sm:text-base">
                        {t.highlight}
                      </p>
                    </div>

                    {/* エピソード（背景を変えて読みやすく） */}
                    {hasEpisode && (
                      <div class="rounded-md border border-white/10 bg-[#2a2a2a] p-4 sm:p-5">
                        <h3 class="font-display text-sm font-bold tracking-widest text-white/70">
                          {t.episodeTitle}
                        </h3>

                        {t.episodes && t.episodes.length > 0 && (
                          <ul class="mt-3 list-disc space-y-4 pl-5 marker:text-murash-red">
                            {t.episodes.map((e) => (
                              <li class="text-sm leading-[1.8] text-[#e5e5e5] sm:text-base">{e}</li>
                            ))}
                          </ul>
                        )}

                        {/* 宮島事件：特に強調 */}
                        {t.feature && (
                          <div class="mt-4 rounded-md border-2 border-murash-red/60 bg-murash-red/5 p-4 sm:p-5">
                            <div class="flex items-center gap-2">
                              <span class="rounded-sm bg-murash-red px-2 py-0.5 font-display text-[10px] font-bold tracking-widest text-white">
                                伝説
                              </span>
                              <h4 class="font-display text-lg font-bold tracking-tight text-white">
                                {t.feature.title}
                              </h4>
                            </div>
                            <p class="mt-3 text-sm leading-[1.9] text-[#e5e5e5] sm:text-base">
                              {t.feature.body}
                            </p>
                          </div>
                        )}
                      </div>
                    )}

                    {/* アクションリンク */}
                    <div class="flex flex-wrap items-center gap-x-5 gap-y-3 border-t border-white/10 pt-5">
                      {t.detail ? (
                        <a
                          href={`/tournaments/${t.urlSlug}`}
                          class="group inline-flex items-center gap-2 rounded-sm bg-murash-red px-4 py-2 font-display text-sm font-semibold tracking-wide text-white transition-colors hover:bg-murash-red-dark"
                        >
                          詳しく読む
                          <span
                            aria-hidden="true"
                            class="transition-transform group-hover:translate-x-1"
                          >
                            →
                          </span>
                        </a>
                      ) : (
                        <span class="inline-flex items-center gap-2 rounded-sm border border-white/15 bg-white/5 px-4 py-2 font-display text-sm font-semibold tracking-wide text-white/40">
                          詳しく読む
                          <span class="rounded-sm border border-white/20 bg-white/5 px-1.5 py-0.5 text-[10px] font-semibold text-white/50">
                            準備中
                          </span>
                        </span>
                      )}
                      <a
                        href={`/players?filter=${t.slug}`}
                        class="group inline-flex items-center gap-2 font-display text-sm font-semibold tracking-wide text-white/70 transition-colors hover:text-murash-red"
                      >
                        この大会のメンバーを見る
                        <span
                          aria-hidden="true"
                          class="transition-transform group-hover:translate-x-1"
                        >
                          →
                        </span>
                      </a>
                    </div>
                  </div>
                </article>
              </li>
            );
          })
        }
      </ol>
    </div>

    <!-- 関連リンク -->
    <div class="mt-14 flex flex-wrap gap-4 border-t border-white/10 pt-10">
      <a
        href="/about"
        class="inline-flex items-center gap-2 rounded-sm bg-murash-red px-6 py-3 font-display text-sm font-semibold tracking-wide text-white transition-colors hover:bg-murash-red-dark"
      >
        ムラッシュFCとは
        <span aria-hidden="true">→</span>
      </a>
      <a
        href="/players"
        class="inline-flex items-center gap-2 rounded-sm border border-white/20 px-6 py-3 font-display text-sm font-semibold tracking-wide text-white transition-colors hover:border-white/40 hover:bg-white/5"
      >
        選手名鑑を見る
      </a>
    </div>
  </section>
</Layout>
