---
import Layout from "../../layouts/Layout.astro";
import { tournaments, type Tournament } from "../../data/tournaments";
import {
  getVideosFor,
  TOURNAMENT_URLSLUG_TO_VIDEO_CATEGORY,
} from "../../data/videos";
import VideoSection from "../../components/VideoSection.astro";

export function getStaticPaths() {
  return tournaments
    .filter((t) => !!t.detail)
    .map((t) => {
      const idx = tournaments.findIndex((x) => x.urlSlug === t.urlSlug);
      return {
        params: { slug: t.urlSlug },
        props: {
          tournament: t,
          prev: tournaments[idx - 1] ?? null,
          next: tournaments[idx + 1] ?? null,
        },
      };
    });
}

interface Props {
  tournament: Tournament;
  prev: Tournament | null;
  next: Tournament | null;
}

const { tournament: t, prev, next } = Astro.props;
const detail = t.detail!;

const videoCategory = TOURNAMENT_URLSLUG_TO_VIDEO_CATEGORY[t.urlSlug];
const videos = videoCategory ? getVideosFor(videoCategory) : [];

// 概要メタ
const meta = [
  { label: "形態", value: t.format },
  { label: "結果", value: t.result },
  ...(t.record ? [{ label: "戦績", value: t.record }] : []),
  ...(t.champion ? [{ label: "優勝", value: t.champion }] : []),
  { label: "開催地", value: detail.hostCountry },
  ...(t.selectionMethod ? [{ label: "選出方式", value: t.selectionMethod }] : []),
];

// **強調** と [text](url) リンク両対応
interface Segment {
  text: string;
  bold?: boolean;
  href?: string;
}
function markupSegments(text: string): Segment[] {
  const re = /(\*\*[^*]+\*\*|\[[^\]]+\]\([^)]+\))/g;
  const parts = text.split(re).filter((p) => p !== "");
  return parts.map<Segment>((p) => {
    if (p.startsWith("**") && p.endsWith("**")) {
      return { text: p.slice(2, -2), bold: true };
    }
    const m = p.match(/^\[([^\]]+)\]\(([^)]+)\)$/);
    if (m) return { text: m[1], href: m[2] };
    return { text: p };
  });
}
---

<Layout
  title={`${t.no} ${t.name}（${t.date}）| 大会の軌跡 | ムラッシュFC ファンサイト（非公認）`}
  description={`${t.no} ${t.name}（${t.date}・${detail.hostCountry}）の詳細レポート。試合の名場面、舞台裏、個性派メンバー＆スタッフ列伝までファン目線で振り返ります。`}
>
  <!-- ページヘッダー -->
  <section class="relative overflow-hidden border-b border-white/10">
    <div class="absolute inset-0 -z-10">
      <div class="absolute inset-0 bg-gradient-to-br from-murash-charcoal via-murash-black to-black"></div>
      <div class="absolute -right-24 -top-24 h-80 w-80 rounded-full bg-murash-red/20 blur-3xl"></div>
    </div>

    <div class="mx-auto max-w-3xl px-4 py-12 sm:px-6 sm:py-16">
      <!-- パンくず -->
      <nav aria-label="パンくず" class="flex flex-wrap items-center gap-2 text-xs text-white/50">
        <a href="/tournaments" class="hover:text-white">大会の軌跡</a>
        <span aria-hidden="true" class="text-white/30">/</span>
        <span class="text-white/70">{t.name}</span>
      </nav>

      <div class="mt-6 flex flex-wrap items-center gap-3">
        <span
          class="rounded-sm bg-murash-red px-2.5 py-1 font-display text-sm font-bold tracking-wide text-white"
        >
          {t.no}
        </span>
        <span class="font-display text-sm font-semibold tracking-wider text-white/40">
          {t.date}
        </span>
      </div>

      <h1
        class="mt-4 font-display text-4xl font-bold leading-tight tracking-tight text-white sm:text-5xl"
      >
        {t.name}
      </h1>

      <!-- 概要メタ -->
      <dl class="mt-6 space-y-2 text-sm">
        {
          meta.map((m) => (
            <div class="flex gap-3">
              <dt class="w-14 shrink-0 pt-0.5 font-display text-xs font-semibold tracking-wider text-white/40">
                {m.label}
              </dt>
              <dd class="leading-relaxed text-[#e5e5e5]">{m.value}</dd>
            </div>
          ))
        }
      </dl>
    </div>
  </section>

  <!-- ビジュアルサマリー：インフォグラフィック -->
  <section class="border-b border-white/10 bg-murash-black">
    <div class="mx-auto max-w-4xl px-4 py-12 sm:px-6 sm:py-16">
      <h2 class="section-heading">
        <span class="section-label-en">HIGHLIGHT</span>
        <span class="section-title-jp text-2xl sm:text-3xl">大会ハイライト</span>
      </h2>
      <div class="mt-3 h-px w-full bg-gradient-to-r from-murash-red/60 to-transparent"></div>

      <figure class="mt-6">
        <img
          src={`/images/infographics/${t.urlSlug}.png`}
          alt={`${t.no} ${t.name}（${t.date}・${detail.hostCountry}）のビジュアルサマリー インフォグラフィック`}
          width="1672"
          height="941"
          loading="lazy"
          decoding="async"
          class="h-auto w-full rounded-md border border-white/10"
        />
        <figcaption
          class="mt-4 block rounded-md border border-murash-red/30 bg-black/60 px-4 py-3 sm:px-5 sm:py-4"
        >
          <p
            class="font-display text-sm font-bold tracking-wide text-white/90 sm:text-base"
          >
            ⚠️ この画像はAIで生成したイメージです
          </p>
          <p class="mt-2 text-xs leading-relaxed text-white/65 sm:text-sm">
            人物のビジュアル・表情・特徴は実在の選手・関係者と異なります。雰囲気を伝えるためのファンアートとしてお楽しみください。一部の漢字表記・スコア等にも揺れがある場合があります。
          </p>
        </figcaption>
      </figure>
    </div>
  </section>

  <!-- 本文 -->
  <article class="mx-auto max-w-3xl px-4 py-16 sm:px-6">
    <div class="space-y-16">
      {
        detail.sections.map((section) => (
          <section>
            <h2 class="flex items-center gap-3 font-display text-2xl font-bold tracking-tight text-white sm:text-3xl">
              {section.icon && (
                <span aria-hidden="true" class="text-3xl">
                  {section.icon}
                </span>
              )}
              {section.title}
            </h2>
            <div class="mt-2 h-px w-full bg-gradient-to-r from-murash-red/60 to-transparent" />

            <div class="mt-7 space-y-10">
              {section.items.map((item) => (
                <div
                  class:list={[
                    item.emphasized
                      ? "rounded-md border-2 border-murash-red/60 bg-murash-red/5 p-5 sm:p-6"
                      : "",
                  ]}
                >
                  {item.emphasized && (
                    <span class="inline-flex items-center rounded-sm bg-murash-red px-2 py-0.5 font-display text-[10px] font-bold tracking-widest text-white">
                      伝説
                    </span>
                  )}
                  {item.title && (
                    <h3
                      class:list={[
                        "flex items-center gap-2 font-display text-lg font-bold tracking-tight text-white sm:text-xl",
                        item.emphasized ? "mt-3" : "",
                      ]}
                    >
                      {!item.emphasized && (
                        <span
                          aria-hidden="true"
                          class="inline-block h-4 w-1 shrink-0 rounded-full bg-murash-red"
                        />
                      )}
                      {item.title}
                    </h3>
                  )}
                  <div class={item.title ? "mt-3 space-y-5" : "space-y-5"}>
                    {item.body.map((p) => (
                      <p class="text-base leading-[1.95] text-[#e5e5e5] sm:text-lg">
                        {markupSegments(p).map((seg) =>
                          seg.bold ? (
                            <strong class="font-semibold text-white">{seg.text}</strong>
                          ) : seg.href ? (
                            <a
                              href={seg.href}
                              class="text-murash-red underline-offset-2 hover:underline"
                            >
                              {seg.text}
                            </a>
                          ) : (
                            seg.text
                          ),
                        )}
                      </p>
                    ))}
                  </div>
                  {item.note && (
                    <p class="mt-3 inline-flex items-start gap-2 rounded-sm border border-white/10 bg-white/5 px-3 py-2 text-xs italic text-white/45">
                      <span class="font-display not-italic text-murash-red">TBD</span>
                      {item.note}
                    </p>
                  )}
                </div>
              ))}
            </div>
          </section>
        ))
      }
    </div>

    {/* コーチング・スタッフ体制 */}
    {
      t.staffRoster && t.staffRoster.length > 0 && (
        <section class="mt-16">
          <h2 class="section-heading">
            <span class="section-label-en">COACHING STAFF</span>
            <span class="section-title-jp text-2xl sm:text-3xl">コーチング・スタッフ体制</span>
          </h2>
          <div class="mt-3 h-px w-full bg-gradient-to-r from-murash-red/60 to-transparent" />
          <ul class="mt-6 space-y-2.5">
            {t.staffRoster.map((s) => (
              <li class="flex items-start gap-3 rounded-md border border-white/10 bg-murash-charcoal px-4 py-3 sm:px-5 sm:py-3.5">
                <span class="w-28 shrink-0 font-display text-xs font-bold tracking-wider text-murash-red sm:w-32 sm:text-sm">
                  {s.role}
                </span>
                <span class="flex flex-wrap items-baseline gap-1 text-sm leading-relaxed text-[#e5e5e5] sm:text-base">
                  {s.playerSlug ? (
                    <a
                      href={`/players/${s.playerSlug}`}
                      class="font-semibold text-white underline-offset-2 hover:text-murash-red hover:underline"
                    >
                      {s.name}
                    </a>
                  ) : (
                    <span class="font-semibold text-white">{s.name}</span>
                  )}
                  {s.noteSuffix && (
                    <span class="text-xs text-white/50 sm:text-sm">{s.noteSuffix}</span>
                  )}
                </span>
              </li>
            ))}
          </ul>
        </section>
      )
    }

    <!-- 情報源の注記 -->
    <aside class="mt-16 rounded-md border border-white/10 bg-white/5 p-4 sm:p-5">
      <p class="text-xs leading-relaxed text-white/55 sm:text-sm">
        ※本記事の内容は、ムラッシュFC公式YouTubeチャンネルおよび加藤純一公式YouTubeチャンネルの配信内容を元にまとめています。記憶違いや解釈の誤りがある可能性があります。
      </p>
    </aside>

    <!-- 前後の大会ナビ -->
    <nav class="mt-10 grid gap-3 border-t border-white/10 pt-8 sm:grid-cols-2">
      {
        prev ? (
          prev.detail ? (
            <a
              href={`/tournaments/${prev.urlSlug}`}
              class="group rounded-md border border-white/10 bg-murash-charcoal p-4 transition-colors hover:border-murash-red/50"
            >
              <span class="font-display text-xs font-semibold tracking-wider text-white/40">
                ← 前の大会
              </span>
              <p class="mt-1.5 font-display text-sm font-bold text-white transition-colors group-hover:text-murash-red">
                {prev.no} {prev.name}
              </p>
            </a>
          ) : (
            <div class="rounded-md border border-dashed border-white/15 bg-white/5 p-4">
              <span class="font-display text-xs font-semibold tracking-wider text-white/40">
                ← 前の大会
              </span>
              <p class="mt-1.5 flex items-center gap-2 font-display text-sm font-bold text-white/60">
                {prev.no} {prev.name}
                <span class="rounded-sm border border-white/20 bg-white/5 px-1.5 py-0.5 text-[10px] font-semibold text-white/50">
                  準備中
                </span>
              </p>
            </div>
          )
        ) : (
          <span class="hidden sm:block" />
        )
      }
      {
        next ? (
          next.detail ? (
            <a
              href={`/tournaments/${next.urlSlug}`}
              class="group rounded-md border border-white/10 bg-murash-charcoal p-4 text-right transition-colors hover:border-murash-red/50"
            >
              <span class="font-display text-xs font-semibold tracking-wider text-white/40">
                次の大会 →
              </span>
              <p class="mt-1.5 font-display text-sm font-bold text-white transition-colors group-hover:text-murash-red">
                {next.no} {next.name}
              </p>
            </a>
          ) : (
            <div class="rounded-md border border-dashed border-white/15 bg-white/5 p-4 text-right">
              <span class="font-display text-xs font-semibold tracking-wider text-white/40">
                次の大会 →
              </span>
              <p class="mt-1.5 flex items-center justify-end gap-2 font-display text-sm font-bold text-white/60">
                {next.no} {next.name}
                <span class="rounded-sm border border-white/20 bg-white/5 px-1.5 py-0.5 text-[10px] font-semibold text-white/50">
                  準備中
                </span>
              </p>
            </div>
          )
        ) : (
          <span class="hidden sm:block" />
        )
      }
    </nav>

    <!-- 関連リンク -->
    <div class="mt-10 flex flex-wrap gap-3 border-t border-white/10 pt-8">
      <a
        href={`/players?filter=${t.slug}`}
        class="inline-flex items-center gap-2 rounded-sm bg-murash-red px-5 py-2.5 font-display text-sm font-semibold tracking-wide text-white transition-colors hover:bg-murash-red-dark"
      >
        この大会のメンバーを見る
        <span aria-hidden="true">→</span>
      </a>
      <a
        href="/tournaments"
        class="inline-flex items-center gap-2 rounded-sm border border-white/20 px-5 py-2.5 font-display text-sm font-semibold tracking-wide text-white transition-colors hover:border-white/40 hover:bg-white/5"
      >
        <span aria-hidden="true">←</span> 大会の軌跡へ戻る
      </a>
    </div>
  </article>

  <VideoSection
    videos={videos}
    title={`${t.name} 関連動画`}
    subtitle={`${t.no} ${t.name}（${t.date}）に関するムラッシュFC公式・加藤純一公式チャンネルなどの動画アーカイブ。`}
  />
</Layout>
