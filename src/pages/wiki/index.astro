---
import Layout from "../../layouts/Layout.astro";
import {
  wikiEntries,
  CATEGORY_ORDER,
  CATEGORY_STYLE,
  type WikiCategory,
} from "../../data/wiki";

// ------------------------------------------------------------
// 大会フィルター用：tournament 列を短いラベルに正規化する。
// 「第1回メキシコ大会」→「メキシコ」等。該当しないもの（"-" / null /
// 未知の表記）は null＝バッジ非表示・特定大会フィルターには非該当。
// ------------------------------------------------------------
const TOUR_ORDER = [
  "メキシコ",
  "イタリア",
  "フランス",
  "ブラジル",
  "再スタート編",
] as const;
type TourLabel = (typeof TOUR_ORDER)[number];

function normalizeTournament(t: string | null): TourLabel | null {
  if (!t) return null;
  if (t.includes("メキシコ")) return "メキシコ";
  if (t.includes("イタリア")) return "イタリア";
  if (t.includes("フランス")) return "フランス";
  if (t.includes("ブラジル")) return "ブラジル";
  if (t.includes("再スタート")) return "再スタート編";
  return null;
}

// 各エントリに正規化した大会ラベルと検索用テキストを付与
const entries = wikiEntries.map((e) => ({
  entry: e,
  tour: normalizeTournament(e.tournament),
  // タイトル・読み・説明・本文・人物・タグをまとめた検索対象（小文字化）
  haystack: [
    e.title,
    e.reading,
    e.summary,
    e.content,
    e.relatedPeople.join(" "),
    e.tags.join(" "),
  ]
    .join(" ")
    .toLowerCase(),
}));

// カテゴリ別件数
const catCounts: Record<WikiCategory, number> = {
  あだ名: 0,
  セリフ: 0,
  "事件・出来事": 0,
};
// 大会別件数
const tourCounts: Record<TourLabel, number> = {
  メキシコ: 0,
  イタリア: 0,
  フランス: 0,
  ブラジル: 0,
  再スタート編: 0,
};
for (const e of entries) {
  catCounts[e.entry.category]++;
  if (e.tour) tourCounts[e.tour]++;
}

const total = wikiEntries.length;
---

<Layout
  title="Wiki | ムラッシュFC ファンサイト（非公認）"
  description="ムラッシュFC独自のあだ名・名セリフ・伝説の事件を集めたファンアーカイブ。検索・カテゴリ・大会で絞り込めます。"
>
  <!-- ページヘッダー -->
  <section class="relative overflow-hidden border-b border-white/10">
    <div class="absolute inset-0 -z-10">
      <div
        class="absolute inset-0 bg-gradient-to-br from-murash-charcoal via-murash-black to-black"
      >
      </div>
      <div
        class="absolute -right-24 -top-24 h-72 w-72 rounded-full bg-murash-red/20 blur-3xl"
      >
      </div>
    </div>

    <div class="mx-auto max-w-5xl px-4 py-16 sm:px-6">
      <p
        class="font-display text-sm font-semibold tracking-[0.3em] text-murash-red"
      >
        WIKI
      </p>
      <h1
        class="mt-3 font-display text-4xl font-bold tracking-tight text-white sm:text-5xl"
      >
        ファンWiki
      </h1>
      <p class="mt-4 text-sm leading-relaxed text-white/60 sm:text-base">
        ムラッシュFCのファンならニヤリとする、独自の用語・事件・名セリフ。動画では一瞬の出来事も、ここで詳しく振り返れます。
      </p>

      <!-- 用語辞典との違いを明示 -->
      <aside
        class="mt-6 flex flex-wrap items-start gap-2 rounded-md border border-white/10 bg-white/5 px-4 py-3 text-xs text-white/55 sm:text-sm"
      >
        <span
          class="rounded-sm border border-white/15 bg-white/5 px-1.5 py-0.5 font-display text-[10px] font-bold tracking-widest text-white/60"
          >NOTE</span
        >
        <span>
          サッカー・キングスリーグ全般の用語は <a
            href="/glossary"
            class="text-murash-red underline-offset-2 hover:underline"
            >用語辞典</a
          > を、ムラッシュFC独自のあだ名・事件・名セリフはこちらをどうぞ。
        </span>
      </aside>

      <!-- 検索ボックス -->
      <div class="relative mt-8">
        <svg
          class="pointer-events-none absolute left-4 top-1/2 -translate-y-1/2 text-white/40"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <circle cx="11" cy="11" r="8"></circle>
          <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
        <input
          type="search"
          id="wiki-search"
          placeholder="タイトル・本文・人物・タグで検索（例: PK、加藤、こうじろう）"
          aria-label="Wikiを検索"
          autocomplete="off"
          class="w-full rounded-md border border-white/10 bg-murash-charcoal py-3.5 pl-11 pr-4 text-sm text-white placeholder:text-white/35 transition-colors focus:border-murash-red focus:outline-none"
        />
      </div>

      <!-- カテゴリフィルター -->
      <div class="mt-6">
        <p
          class="mb-2 font-display text-[11px] font-bold tracking-[0.15em] text-white/40"
        >
          カテゴリ
        </p>
        <div class="flex flex-wrap gap-2" data-group="cat" aria-label="カテゴリ">
          <button
            type="button"
            data-val="すべて"
            aria-pressed="true"
            class="wiki-chip"
          >
            すべて<span class="chip-cnt">{total}</span>
          </button>
          {
            CATEGORY_ORDER.map((cat) => (
              <button
                type="button"
                data-val={cat}
                aria-pressed="false"
                class="wiki-chip"
              >
                <span
                  class:list={[
                    "inline-block h-2 w-2 rounded-full",
                    CATEGORY_STYLE[cat].dot,
                  ]}
                />
                {cat}
                <span class="chip-cnt">{catCounts[cat]}</span>
              </button>
            ))
          }
        </div>
      </div>

      <!-- 大会フィルター -->
      <div class="mt-4">
        <p
          class="mb-2 font-display text-[11px] font-bold tracking-[0.15em] text-white/40"
        >
          大会
        </p>
        <div class="flex flex-wrap gap-2" data-group="tour" aria-label="大会">
          <button
            type="button"
            data-val="すべて"
            aria-pressed="true"
            class="wiki-chip"
          >
            すべて<span class="chip-cnt">{total}</span>
          </button>
          {
            TOUR_ORDER.map((t) => (
              <button
                type="button"
                data-val={t}
                aria-pressed="false"
                class="wiki-chip"
              >
                {t}
                <span class="chip-cnt">{tourCounts[t]}</span>
              </button>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- 一覧 -->
  <section class="mx-auto max-w-5xl px-4 py-10 sm:px-6 sm:py-12">
    <!-- 結果件数 -->
    <p id="wiki-result" class="mb-4 text-sm text-white/50">
      <b class="font-semibold text-murash-red">{total}</b>件を表示
    </p>

    <div
      id="wiki-grid"
      class="grid grid-cols-1 gap-3.5 sm:grid-cols-2 lg:grid-cols-3"
    >
      {
        entries.map(({ entry: e, tour, haystack }) => {
          const style = CATEGORY_STYLE[e.category];
          return (
            <a
              href={`/wiki/${e.slug}`}
              class:list={[
                "wiki-card group relative flex flex-col overflow-hidden rounded-lg border border-white/10 bg-murash-charcoal p-4 pb-3.5 transition-all duration-200 hover:-translate-y-[3px] hover:border-murash-red/60 hover:shadow-[0_8px_24px_rgba(230,0,18,0.12)]",
              ]}
              data-category={e.category}
              data-tour={tour ?? ""}
              data-tags={e.tags.join(",")}
              data-search={haystack}
            >
              <div class="flex flex-wrap items-center gap-2">
                <span
                  class:list={[
                    "inline-flex items-center gap-1 rounded-sm border px-2 py-0.5 font-display text-[10px] font-bold tracking-widest",
                    style.badge,
                  ]}
                >
                  {e.category}
                </span>
                {tour && (
                  <span class="rounded-sm border border-white/15 bg-white/5 px-2 py-0.5 font-display text-[10px] font-semibold tracking-wide text-white/50">
                    {tour}
                  </span>
                )}
              </div>

              <h3 class="mt-3 font-display text-base font-bold leading-snug tracking-tight text-white transition-colors group-hover:text-murash-red">
                {e.title}
              </h3>
              <p class="mt-0.5 text-[11px] text-white/35">{e.reading}</p>

              <p class="mt-2 line-clamp-3 flex-1 text-[12.5px] leading-relaxed text-white/60">
                {e.summary}
              </p>

              {e.tags.length > 0 && (
                <div class="mt-3 flex flex-wrap gap-1.5 pr-6">
                  {e.tags.slice(0, 4).map((tag) => (
                    <button
                      type="button"
                      class="wiki-tag rounded-sm bg-white/5 px-1.5 py-0.5 text-[10px] font-medium text-white/45 transition-colors hover:bg-murash-red hover:text-white"
                      data-tag={tag}
                    >
                      #{tag}
                    </button>
                  ))}
                </div>
              )}

              <span
                aria-hidden="true"
                class="absolute bottom-3 right-3.5 text-sm text-white/25 transition-colors group-hover:text-murash-red"
              >
                →
              </span>
            </a>
          );
        })
      }
    </div>

    <p
      id="wiki-empty"
      class="hidden py-16 text-center text-sm text-white/40"
    >
      該当するエントリがありません。
    </p>
  </section>
</Layout>

<style>
  .wiki-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    white-space: nowrap;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    background-color: var(--color-murash-charcoal);
    padding: 0.4rem 0.85rem;
    font-size: 0.8125rem;
    color: rgba(255, 255, 255, 0.7);
    cursor: pointer;
    transition:
      color 0.15s,
      background-color 0.15s,
      border-color 0.15s;
    user-select: none;
  }
  .wiki-chip:hover {
    border-color: rgba(230, 0, 18, 0.5);
    color: #fff;
  }
  .wiki-chip[aria-pressed="true"] {
    background-color: var(--color-murash-red);
    border-color: var(--color-murash-red);
    color: #fff;
    font-weight: 700;
  }
  .chip-cnt {
    font-size: 0.6875rem;
    opacity: 0.7;
    margin-left: 0.15rem;
  }
  .wiki-chip[aria-pressed="true"] .chip-cnt {
    opacity: 0.85;
  }
</style>

<script>
  type Group = "cat" | "tour";
  const state = { cat: "すべて", tour: "すべて", q: "", tag: "" };

  const cards = Array.from(
    document.querySelectorAll<HTMLAnchorElement>("#wiki-grid .wiki-card"),
  );
  const searchInput =
    document.querySelector<HTMLInputElement>("#wiki-search");
  const resultInfo = document.querySelector<HTMLElement>("#wiki-result");
  const emptyEl = document.querySelector<HTMLElement>("#wiki-empty");

  // チップ（カテゴリ・大会）のクリック → active 切り替え & 再描画
  document
    .querySelectorAll<HTMLElement>('[data-group="cat"], [data-group="tour"]')
    .forEach((groupEl) => {
      const group = groupEl.dataset.group as Group;
      const chips = Array.from(
        groupEl.querySelectorAll<HTMLButtonElement>(".wiki-chip"),
      );
      chips.forEach((chip) => {
        chip.addEventListener("click", () => {
          chips.forEach((c) =>
            c.setAttribute("aria-pressed", String(c === chip)),
          );
          state[group] = chip.dataset.val ?? "すべて";
          render();
        });
      });
    });

  // 検索入力：リアルタイム絞り込み（タグ絞り込みは解除）
  searchInput?.addEventListener("input", () => {
    state.q = searchInput.value.trim();
    if (state.q) state.tag = "";
    render();
  });

  // タグクリック：同タグで絞り込み（カードリンクへの遷移は抑止）
  cards.forEach((card) => {
    card
      .querySelectorAll<HTMLButtonElement>(".wiki-tag")
      .forEach((tagBtn) => {
        tagBtn.addEventListener("click", (ev) => {
          ev.preventDefault();
          ev.stopPropagation();
          state.tag = tagBtn.dataset.tag ?? "";
          state.q = "";
          if (searchInput) searchInput.value = "";
          render();
        });
      });
  });

  function render() {
    const q = state.q.toLowerCase();
    let visible = 0;

    cards.forEach((card) => {
      const cat = card.dataset.category ?? "";
      const tour = card.dataset.tour ?? "";
      const tags = (card.dataset.tags ?? "").split(",").filter(Boolean);
      const hay = card.dataset.search ?? "";

      const show =
        (state.cat === "すべて" || cat === state.cat) &&
        (state.tour === "すべて" || tour === state.tour) &&
        (!state.tag || tags.includes(state.tag)) &&
        (!q || hay.includes(q));

      card.hidden = !show;
      if (show) visible++;
    });

    // 結果件数（＋タグ絞り込み中はクリア導線）
    if (resultInfo) {
      let html = `<b class="font-semibold text-murash-red">${visible}</b>件を表示`;
      if (state.tag) {
        html += ` <span class="text-white/40">／ タグ:</span> <b class="font-semibold text-murash-red">#${state.tag}</b> <button type="button" id="wiki-tag-clear" class="ml-1 text-white/50 underline underline-offset-2 hover:text-white">×クリア</button>`;
      }
      resultInfo.innerHTML = html;
      document
        .querySelector<HTMLButtonElement>("#wiki-tag-clear")
        ?.addEventListener("click", () => {
          state.tag = "";
          render();
        });
    }

    if (emptyEl) emptyEl.hidden = visible !== 0;
  }

  render();
</script>
