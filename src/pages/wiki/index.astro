---
import Layout from "../../layouts/Layout.astro";
import {
  wikiEntries,
  CATEGORY_ORDER,
  CATEGORY_STYLE,
  type WikiCategory,
} from "../../data/wiki";

// カテゴリ別件数
const counts: Record<WikiCategory, number> = {
  あだ名: 0,
  セリフ: 0,
  "事件・出来事": 0,
};
for (const e of wikiEntries) counts[e.category]++;
---

<Layout
  title="Wiki | ムラッシュFC ファンサイト（非公認）"
  description="ムラッシュFC独自のあだ名・名セリフ・伝説の事件を集めたファンアーカイブ。動画では一瞬の出来事も詳しく振り返れます。"
>
  <!-- ページヘッダー -->
  <section class="relative overflow-hidden border-b border-white/10">
    <div class="absolute inset-0 -z-10">
      <div
        class="absolute inset-0 bg-gradient-to-br from-murash-charcoal via-murash-black to-black"
      >
      </div>
      <div
        class="absolute -right-24 -top-24 h-72 w-72 rounded-full bg-murash-red/20 blur-3xl"
      >
      </div>
    </div>

    <div class="mx-auto max-w-4xl px-4 py-16 sm:px-6">
      <p
        class="font-display text-sm font-semibold tracking-[0.3em] text-murash-red"
      >
        WIKI
      </p>
      <h1
        class="mt-3 font-display text-4xl font-bold tracking-tight text-white sm:text-5xl"
      >
        ファンWiki
      </h1>
      <p class="mt-4 text-sm leading-relaxed text-white/60 sm:text-base">
        ムラッシュFCのファンならニヤリとする、独自の用語・事件・名セリフ。動画では一瞬の出来事も、ここで詳しく振り返れます。
      </p>

      <!-- 用語辞典との違いを明示 -->
      <aside
        class="mt-6 flex flex-wrap items-start gap-2 rounded-md border border-white/10 bg-white/5 px-4 py-3 text-xs text-white/55 sm:text-sm"
      >
        <span
          class="rounded-sm border border-white/15 bg-white/5 px-1.5 py-0.5 font-display text-[10px] font-bold tracking-widest text-white/60"
          >NOTE</span
        >
        <span>
          サッカー・キングスリーグ全般の用語は <a
            href="/glossary"
            class="text-murash-red underline-offset-2 hover:underline"
            >用語辞典</a
          > を、ムラッシュFC独自のあだ名・事件・名セリフはこちらをどうぞ。
        </span>
      </aside>

      <!-- カテゴリフィルター -->
      <div
        class="mt-8 flex flex-wrap gap-2"
        role="tablist"
        aria-label="カテゴリ"
      >
        <button
          type="button"
          data-filter="all"
          aria-pressed="true"
          class="filter-btn inline-flex items-center gap-1.5 rounded-sm border border-white/10 bg-white/5 px-3 py-1.5 font-display text-xs font-semibold tracking-wide text-white/70 transition-colors hover:text-white"
        >
          すべて
          <span class="text-white/40">{wikiEntries.length}</span>
        </button>
        {
          CATEGORY_ORDER.map((cat) => (
            <button
              type="button"
              data-filter={cat}
              aria-pressed="false"
              class="filter-btn inline-flex items-center gap-1.5 rounded-sm border border-white/10 bg-white/5 px-3 py-1.5 font-display text-xs font-semibold tracking-wide text-white/70 transition-colors hover:text-white"
            >
              <span class:list={["inline-block h-2 w-2 rounded-full", CATEGORY_STYLE[cat].dot]} />
              {cat}
              <span class="text-white/40">{counts[cat]}</span>
            </button>
          ))
        }
      </div>
    </div>
  </section>

  <!-- 一覧 -->
  <section class="mx-auto max-w-4xl px-4 py-12 sm:px-6 sm:py-16">
    <ul id="wiki-list" class="space-y-4">
      {
        wikiEntries.map((e) => {
          const style = CATEGORY_STYLE[e.category];
          return (
            <li data-category={e.category}>
              <a
                href={`/wiki/${e.slug}`}
                class:list={[
                  "group block overflow-hidden rounded-md border border-white/10 bg-murash-charcoal p-5 transition-all duration-300 hover:-translate-y-0.5 sm:p-6",
                  style.hover,
                ]}
              >
                <div class="flex flex-wrap items-center gap-2">
                  <span
                    class:list={[
                      "inline-flex items-center gap-1 rounded-sm border px-2 py-0.5 font-display text-[10px] font-bold tracking-widest",
                      style.badge,
                    ]}
                  >
                    {e.category}
                  </span>
                  {e.tournament && (
                    <span class="rounded-sm border border-white/15 bg-white/5 px-2 py-0.5 font-display text-[10px] font-semibold tracking-wide text-white/60">
                      {e.tournament}
                    </span>
                  )}
                </div>

                <h2 class="mt-3 font-display text-xl font-bold tracking-tight text-white transition-colors group-hover:text-murash-red sm:text-2xl">
                  {e.title}
                </h2>
                <p class="mt-0.5 text-xs text-white/40">{e.reading}</p>

                <p class="mt-3 text-sm leading-[1.85] text-[#e5e5e5]">
                  {e.summary}
                </p>

                {e.tags.length > 0 && (
                  <div class="mt-4 flex flex-wrap gap-1.5">
                    {e.tags.map((tag) => (
                      <span class="rounded-sm border border-white/10 bg-white/5 px-1.5 py-0.5 text-[10px] font-medium tracking-wide text-white/45">
                        #{tag}
                      </span>
                    ))}
                  </div>
                )}

                <span class="mt-4 inline-flex items-center gap-1 font-display text-xs font-semibold tracking-wide text-white/50 transition-colors group-hover:text-murash-red">
                  詳しく見る
                  <span
                    aria-hidden="true"
                    class="transition-transform group-hover:translate-x-0.5"
                  >
                    →
                  </span>
                </span>
              </a>
            </li>
          );
        })
      }
    </ul>
    <p id="wiki-empty" class="mt-6 hidden text-sm text-white/40">
      該当する項目が見つかりませんでした。
    </p>
  </section>
</Layout>

<style>
  .filter-btn[aria-pressed="true"] {
    background-color: #e60012;
    border-color: transparent;
    color: #fff;
  }
  .filter-btn[aria-pressed="true"] span {
    color: rgba(255, 255, 255, 0.85);
  }
</style>

<script>
  const filterBtns = document.querySelectorAll<HTMLButtonElement>("[data-filter]");
  const items = document.querySelectorAll<HTMLLIElement>("#wiki-list > li");
  const empty = document.getElementById("wiki-empty");

  filterBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      const f = btn.dataset.filter ?? "all";
      filterBtns.forEach((b) =>
        b.setAttribute("aria-pressed", String(b === btn)),
      );
      let visible = 0;
      items.forEach((li) => {
        const show = f === "all" || li.dataset.category === f;
        li.hidden = !show;
        if (show) visible++;
      });
      if (empty) empty.hidden = visible !== 0;
    });
  });
</script>
