---
import Layout from "../layouts/Layout.astro";

const sections = [
  {
    label: "ムラッシュFCとは",
    href: "/about",
    desc: "加藤純一がオーナーを務めるキングスリーグ日本チーム。その成り立ちと魅力を紹介。",
    no: "01",
  },
  {
    label: "選手名鑑",
    href: "/players",
    desc: "ピッチを駆けるムラッシュFCの選手たちを一覧でチェック。",
    no: "02",
  },
  {
    label: "大会の軌跡",
    href: "/tournaments",
    desc: "これまで戦ってきた大会の結果と名場面をまとめてアーカイブ。",
    no: "03",
  },
  {
    label: "歴史・年表",
    href: "/history",
    desc: "チーム結成から現在までの歩みを時系列で振り返る。",
    no: "04",
  },
  {
    label: "用語辞典",
    href: "/glossary",
    desc: "キングスリーグ・ムラッシュFC特有の用語をやさしく解説。",
    no: "05",
  },
  {
    label: "ブログ",
    href: "/blog",
    desc: "試合の感想やファン目線のコラムを不定期で更新中。",
    no: "06",
  },
];
---

<Layout>
  <!-- ヒーロー -->
  <section class="relative overflow-hidden border-b border-white/10">
    <!-- 背景の装飾 -->
    <div class="absolute inset-0 -z-10">
      <div class="absolute inset-0 bg-gradient-to-br from-murash-charcoal via-murash-black to-black"></div>
      <div
        class="absolute -right-24 -top-24 h-96 w-96 rounded-full bg-murash-red/20 blur-3xl"
      >
      </div>
      <div
        class="absolute inset-0 opacity-[0.04]"
        style="background-image: linear-gradient(to right, white 1px, transparent 1px), linear-gradient(to bottom, white 1px, transparent 1px); background-size: 48px 48px;"
      >
      </div>
    </div>

    <div class="mx-auto max-w-6xl px-4 py-24 sm:px-6 sm:py-32">
      <p class="font-display text-sm font-semibold tracking-[0.3em] text-murash-red">
        UNOFFICIAL FAN SITE
      </p>
      <h1
        class="mt-4 font-display text-5xl font-bold leading-none tracking-tight text-white sm:text-7xl lg:text-8xl"
      >
        MURASH FC
        <span class="mt-2 block text-2xl font-semibold text-white/70 sm:text-3xl">
          ムラッシュFC ファンサイト
        </span>
      </h1>
      <p class="mt-6 max-w-xl text-base leading-relaxed text-white/60 sm:text-lg">
        加藤純一がオーナーを務めるキングスリーグ日本チーム「ムラッシュFC」。<br
          class="hidden sm:block"
        />選手・大会・歴史を、ファン目線でまるごとアーカイブ。
      </p>

      <div class="mt-10 flex flex-wrap gap-4">
        <a
          href="/about"
          class="inline-flex items-center gap-2 rounded-sm bg-murash-red px-6 py-3 font-display text-sm font-semibold tracking-wide text-white transition-colors hover:bg-murash-red-dark"
        >
          ムラッシュFCとは
          <span aria-hidden="true">→</span>
        </a>
        <a
          href="/players"
          class="inline-flex items-center gap-2 rounded-sm border border-white/20 px-6 py-3 font-display text-sm font-semibold tracking-wide text-white transition-colors hover:border-white/40 hover:bg-white/5"
        >
          選手名鑑を見る
        </a>
      </div>
    </div>
  </section>

  <!-- コンテンツ一覧 -->
  <section class="mx-auto max-w-6xl px-4 py-20 sm:px-6">
    <div class="flex items-end justify-between">
      <div>
        <p class="font-display text-sm font-semibold tracking-[0.3em] text-murash-red">CONTENTS</p>
        <h2 class="mt-2 font-display text-3xl font-bold tracking-tight text-white sm:text-4xl">
          コンテンツ一覧
        </h2>
      </div>
    </div>

    <div class="mt-10 grid gap-px overflow-hidden rounded-md border border-white/10 bg-white/10 sm:grid-cols-2 lg:grid-cols-3">
      {
        sections.map((s) => (
          <a
            href={s.href}
            class="group relative flex flex-col bg-murash-charcoal p-6 transition-colors hover:bg-murash-black"
          >
            <span class="font-display text-sm font-semibold tracking-widest text-white/30 transition-colors group-hover:text-murash-red">
              {s.no}
            </span>
            <h3 class="mt-3 flex items-center gap-2 font-display text-xl font-bold text-white">
              {s.label}
              <span
                aria-hidden="true"
                class="translate-x-0 text-murash-red opacity-0 transition-all group-hover:translate-x-1 group-hover:opacity-100"
              >
                →
              </span>
            </h3>
            <p class="mt-2 text-sm leading-relaxed text-white/50">{s.desc}</p>
          </a>
        ))
      }
    </div>
  </section>

  <!-- 注意書きバナー -->
  <section class="mx-auto max-w-6xl px-4 pb-20 sm:px-6">
    <div class="rounded-md border border-murash-red/30 bg-murash-red/5 p-6">
      <p class="text-sm leading-relaxed text-white/70">
        <span class="font-semibold text-murash-red">⚠ 非公認サイトです。</span>
        当サイトはファンが個人的に運営しているもので、ムラッシュFC・キングスリーグ公式とは一切関係ありません。
        公式情報は
        <a
          href="https://murash.win"
          target="_blank"
          rel="noopener noreferrer"
          class="text-murash-red underline-offset-2 hover:underline">murash.win</a
        >
        をご確認ください。
      </p>
    </div>
  </section>
</Layout>
