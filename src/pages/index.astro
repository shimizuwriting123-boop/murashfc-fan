---
import Layout from "../layouts/Layout.astro";
import { tournaments } from "../data/tournaments";

/**
 * NEXT MATCH：日時は tournaments.ts の exhibitionMatches を唯一の情報源とする
 * （詳細ページと値を共有するため、ここでは日時をハードコードしない）。
 * 実際のカウントダウン対象（現在時刻より後で最も近い試合）は、
 * ビルド時刻に依存しないようクライアント側スクリプトで決定する。
 */
const NEXT_MATCH_TOURNAMENT = tournaments.find(
  (t) => t.exhibitionMatches && t.exhibitionMatches.length > 0,
);
const upcomingMatches = NEXT_MATCH_TOURNAMENT?.exhibitionMatches ?? [];

/**
 * 見出しの改行位置を制御するためのチャンク。
 * CJK は全文字が改行可能なため、そのままだと「エキシビジ／ョンマッチ」のように
 * 語の途中で折れてしまう。`.next-match-title { word-break: keep-all }` で任意改行を止め、
 * ここで分割した意味の切れ目にだけ <wbr> を入れて折り返させる。
 */
const NEXT_MATCH_NAME_CHUNKS = [
  "キングス・",
  "ワールドカップ",
  " エキシビジョン",
  "マッチ",
];

const NEXT_MATCH = {
  name: NEXT_MATCH_NAME_CHUNKS.join(""),
  location: "イタリア／ミラノ",
  dateLabel: "2026年7月28日〜31日",
  detailUrl: NEXT_MATCH_TOURNAMENT
    ? `/tournaments/${NEXT_MATCH_TOURNAMENT.urlSlug}`
    : "/tournaments",
};

/**
 * 大会戦績カード用のデータを tournaments.ts から導出する。
 * data 側は `result: "1勝2敗・ベスト32敗退"` のように "・" 区切りで保持しており、
 * TOP では先頭を大きな赤文字（勝敗）、後半を小さなサブ表示（敗退ステージ）として表示する。
 */
const yearMonth = (date: string) => {
  const m = date.match(/(\d{4})年(\d{1,2})月/);
  return m ? `${m[1]}.${m[2]}` : date;
};
const results = tournaments.map((t, i) => {
  const parts = t.result.split("・").map((s) => s.trim()).filter(Boolean);
  // 形式: "X勝Y敗・ステージ" の場合は前半を赤大文字、後半をサブ表示に分割。
  // "・" が無い場合は record=null、result=全文（敗退理由のみ表示）。
  const hasSplit = parts.length >= 2;
  return {
    no: t.no,
    index: String(i + 1).padStart(2, "0"),
    name: t.name,
    ym: yearMonth(t.date),
    record: hasSplit ? parts[0] : null,
    result: hasSplit ? parts.slice(1).join("・") : parts[0],
    urlSlug: t.urlSlug,
    hasDetail: !!t.detail,
    upcoming: !!t.upcoming,
  };
});

interface Section {
  no: string;
  label: string;
  href: string;
  sub: string;
}

// 物語の流れ：入り口 → 誰が → 過去 → 時系列 → 解説 → 小ネタ → 雑記
const sections: Section[] = [
  {
    no: "01",
    label: "ムラッシュFCとは",
    href: "/about",
    sub: "加藤純一がオーナーを務めるキングスリーグ日本チーム。その成り立ちと魅力。",
  },
  {
    no: "02",
    label: "選手名鑑",
    href: "/players",
    sub: "現メンバー 16 名と歴代メンバー・スタッフのプロフィール。",
  },
  {
    no: "03",
    label: "大会の軌跡",
    href: "/tournaments",
    sub: "メキシコ・イタリア・フランス・ブラジル 4 大会の名場面アーカイブ。",
  },
  {
    no: "04",
    label: "再スタート編",
    href: "/rebirth",
    sub: "ブラジル大会後の組織改革から新生16名誕生までの全6章ドキュメンタリー。",
  },
  {
    no: "05",
    label: "歴史・年表",
    href: "/history",
    sub: "キングスリーグ誕生から新生ムラッシュFCまでの歩みを時系列で。",
  },
  {
    no: "06",
    label: "用語辞典",
    href: "/glossary",
    sub: "キングスリーグ・ムラッシュFC特有の用語をやさしく解説。",
  },
  {
    no: "07",
    label: "Wiki",
    href: "/wiki",
    sub: "あだ名・名セリフ・伝説の事件をまとめたファンアーカイブ。",
  },
  {
    no: "08",
    label: "ブログ",
    href: "/blog",
    sub: "試合の感想やファン目線のコラムを不定期で更新中。",
  },
];


const visualTimeline = [
  {
    no: "第1回",
    label: "メキシコ大会",
    image: "/images/infographics/mexico-2024.webp",
    href: "/tournaments/mexico-2024",
    w: 1672,
    h: 941,
    contain: false,
  },
  {
    no: "第2回",
    label: "イタリア大会",
    image: "/images/infographics/italy-2025.webp",
    href: "/tournaments/italy-2025",
    w: 1672,
    h: 941,
    contain: false,
  },
  {
    no: "第3回",
    label: "フランス大会",
    image: "/images/infographics/france-2025.webp",
    href: "/tournaments/france-2025",
    w: 1672,
    h: 941,
    contain: false,
  },
  {
    no: "第4回",
    label: "ブラジル大会",
    image: "/images/infographics/brazil-2026.webp",
    href: "/tournaments/brazil-2026",
    w: 1672,
    h: 941,
    contain: false,
  },
  {
    no: "特集",
    label: "再スタート編",
    image: "/images/infographics/rebirth.webp",
    href: "/rebirth",
    w: 941,
    h: 1672,
    contain: true,
  },
];
---

<Layout>
  <!-- ヒーロー -->
  <section class="relative overflow-hidden border-b border-white/10">
    <!-- 背景：バナー画像 + 多層オーバーレイ -->
    <div class="absolute inset-0 -z-10">
      <img
        src="/images/hero-banner.webp"
        alt="ムラッシュFC 円陣を組む選手たちと不死鳥"
        width="1280"
        height="720"
        fetchpriority="high"
        decoding="async"
        loading="eager"
        class="absolute inset-0 h-full w-full object-cover object-center opacity-90"
      />
      <!-- グラデーションシャドウ：テキスト領域だけ強めに暗くし、画像中央〜右側の不死鳥は明るく残す -->
      <div
        class="absolute inset-0"
        style="background: linear-gradient(135deg, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.6) 50%, transparent 80%);"
      >
      </div>
      <!-- 既存の赤グロー -->
      <div class="absolute -right-24 -top-24 h-96 w-96 rounded-full bg-murash-red/20 blur-3xl"></div>
      <!-- 既存のグリッド -->
      <div
        class="grid-bg absolute inset-0 opacity-[0.035]"
        style="background-image: linear-gradient(to right, white 1px, transparent 1px), linear-gradient(to bottom, white 1px, transparent 1px); background-size: 48px 48px;"
      >
      </div>
    </div>

    <div class="mx-auto max-w-6xl px-4 py-24 pb-32 sm:px-6 sm:py-32 sm:pb-36">
      <p
        class="hero-label-en text-sm tracking-[0.4em] text-murash-red [text-shadow:0_2px_8px_rgba(0,0,0,0.8)]"
      >
        UNOFFICIAL FAN SITE
      </p>
      <h1
        class="hero-title-en mt-4 text-6xl leading-[0.95] text-white [text-shadow:0_3px_12px_rgba(0,0,0,0.85)] sm:text-8xl lg:text-9xl"
      >
        <span class="glow-text">MURASH FC</span>
        <span
          class="hero-title-jp mt-3 block text-2xl text-white/95 sm:text-3xl"
        >
          ムラッシュFC ファンサイト
        </span>
      </h1>
      <p
        class="mt-6 max-w-xl text-base font-medium leading-[1.75] text-white/90 [text-shadow:0_2px_8px_rgba(0,0,0,0.75)] sm:text-lg"
      >
        加藤純一がオーナーを務めるキングスリーグ日本チーム「ムラッシュFC」。<br
          class="hidden sm:block"
        />選手・大会・歴史を、ファン目線でまるごとアーカイブ。
      </p>

      <div class="mt-10 flex flex-wrap gap-4">
        <a
          href="/about"
          class="inline-flex items-center gap-2 rounded-sm bg-murash-red px-6 py-3 font-display text-sm font-bold tracking-wide text-white shadow-lg shadow-black/40 transition-colors hover:bg-murash-red-dark"
        >
          ムラッシュFCとは
          <span aria-hidden="true">→</span>
        </a>
        <a
          href="/players"
          class="inline-flex items-center gap-2 rounded-sm border border-white/25 bg-black/60 px-6 py-3 font-display text-sm font-bold tracking-wide text-white shadow-lg shadow-black/40 backdrop-blur-sm transition-colors hover:border-white/40 hover:bg-black/70"
        >
          選手名鑑を見る
        </a>
      </div>
    </div>

    <!-- スクロール促し -->
    <a
      href="#next-match"
      aria-label="次のセクションへスクロール"
      class="scroll-arrow absolute bottom-6 left-1/2 flex -translate-x-1/2 flex-col items-center gap-1.5 text-white/50 transition-colors hover:text-white"
    >
      <span class="font-display text-[10px] font-semibold tracking-[0.3em]">SCROLL</span>
      <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
      </svg>
    </a>
  </section>

  <!-- NEXT MATCH カウントダウン -->
  <section id="next-match" class="relative overflow-hidden border-b border-white/10 bg-murash-black">
    <!-- 背景演出：斜めの赤ライン + 赤グロー -->
    <div class="pointer-events-none absolute inset-0 -z-0">
      <div
        class="absolute inset-0 opacity-[0.05]"
        style="background-image: repeating-linear-gradient(135deg, transparent 0, transparent 64px, rgba(230,0,18,1) 64px, rgba(230,0,18,1) 65px);"
      >
      </div>
      <div class="absolute -left-24 top-1/3 h-72 w-72 rounded-full bg-murash-red/15 blur-3xl"></div>
      <div class="absolute -right-24 bottom-0 h-64 w-64 rounded-full bg-murash-red/10 blur-3xl"></div>
    </div>

    <div class="relative mx-auto max-w-5xl px-4 py-20 sm:px-6 sm:py-28">
      <!-- セクション見出し -->
      <div class="flex items-center justify-center gap-3">
        <span class="h-5 w-1.5 rounded-full bg-murash-red"></span>
        <p class="font-display text-base font-bold tracking-[0.45em] text-murash-red sm:text-lg">
          NEXT MATCH
        </p>
        <span class="h-5 w-1.5 rounded-full bg-murash-red"></span>
      </div>

      <!-- 試合情報カード -->
      <div
        class="next-match-card mt-8 overflow-hidden rounded-lg border border-murash-red/30 bg-gradient-to-br from-murash-charcoal/90 to-murash-black/95 p-6 sm:mt-10 sm:p-12"
      >
        <h2
          class="next-match-title text-center font-display text-3xl font-bold leading-tight tracking-tight text-white sm:text-5xl"
        >
          {
            NEXT_MATCH_NAME_CHUNKS.map((chunk, i) => (
              <>
                {i > 0 && <wbr />}
                {chunk}
              </>
            ))
          }
        </h2>

        <div
          class="mt-5 flex flex-wrap items-center justify-center gap-x-7 gap-y-2 text-base text-white/85 sm:text-lg"
        >
          <span class="inline-flex items-center gap-2">
            <span aria-hidden="true" class="text-2xl leading-none">🇮🇹</span>
            {NEXT_MATCH.location}
          </span>
          <span class="inline-flex items-center gap-2">
            <span aria-hidden="true" class="text-lg leading-none">🗓</span>
            {NEXT_MATCH.dateLabel}
          </span>
        </div>

        <!-- 次戦ラベル（JSで対象試合名を差し込む） -->
        <p
          id="cd-target-label"
          class="mt-4 text-center font-display text-sm font-semibold tracking-wide text-murash-red-light sm:text-base"
        >
        </p>

        <!-- KICK OFF ラベル -->
        <div class="mt-12 flex items-center justify-center gap-3 sm:mt-16">
          <span
            aria-hidden="true"
            class="h-px w-16 bg-gradient-to-r from-transparent to-murash-red/70 sm:w-24"
          ></span>
          <p
            class="font-display text-sm font-bold tracking-[0.4em] text-murash-red sm:text-base"
          >
            ⚡ KICK OFF まで
          </p>
          <span
            aria-hidden="true"
            class="h-px w-16 bg-gradient-to-l from-transparent to-murash-red/70 sm:w-24"
          ></span>
        </div>

        <!-- カウントダウン -->
        <div
          id="countdown"
          data-matches={JSON.stringify(
            upcomingMatches.map((m) => ({
              no: m.no,
              opponent: m.opponent,
              iso: m.iso,
            })),
          )}
          class="countdown-pulse mt-8 grid grid-cols-4 gap-3 rounded-lg p-2 sm:mt-10 sm:gap-4 sm:p-3"
        >
          {
            [
              { id: "cd-days", label: "日" },
              { id: "cd-hours", label: "時間" },
              { id: "cd-mins", label: "分" },
              { id: "cd-secs", label: "秒" },
            ].map((u) => (
              <div class="countdown-cell group relative flex flex-col items-center justify-center rounded-md border border-white/15 bg-black/55 px-2 py-5 transition-all duration-300 hover:-translate-y-0.5 hover:border-murash-red/50 hover:bg-black/70 sm:py-7">
                <div
                  id={u.id}
                  class="cd-num font-display text-4xl font-bold tabular-nums leading-none text-white min-[380px]:text-5xl sm:text-7xl lg:text-8xl"
                  style="text-shadow: 0 0 32px rgba(230,0,18,0.35), 0 0 10px rgba(230,0,18,0.25);"
                >
                  --
                </div>
                <span
                  aria-hidden="true"
                  class="mx-auto mt-3 block h-0.5 w-8 bg-gradient-to-r from-transparent via-murash-red to-transparent transition-all group-hover:w-14 sm:w-12"
                />
                <div class="mt-2 font-display text-[11px] font-semibold tracking-[0.25em] text-white/55 sm:text-xs">
                  {u.label}
                </div>
              </div>
            ))
          }
        </div>

        <p
          id="cd-note"
          class="mt-6 hidden text-center text-xs text-white/35 sm:mt-8"
        >
        </p>

        <!-- エキシビ3試合の一覧（次戦は data-next="true" で強調） -->
        {
          upcomingMatches.length > 0 && (
            <ul id="match-list" class="mt-8 grid gap-3 sm:mt-10 sm:grid-cols-3">
              {upcomingMatches.map((m) => (
                <li
                  data-match-item
                  data-iso={m.iso}
                  class="match-item flex h-full flex-col rounded-md border border-white/10 bg-black/45 p-4 transition-colors"
                >
                  <div class="flex items-center gap-2">
                    <span class="font-display text-xs font-bold tracking-widest text-white/45">
                      {m.no}
                    </span>
                    <span
                      data-next-badge
                      class="hidden rounded-sm bg-murash-red px-1.5 py-0.5 font-display text-[10px] font-bold tracking-widest text-white"
                    >
                      次戦
                    </span>
                  </div>
                  <p class="mt-1.5 font-display text-lg font-bold leading-snug text-white">
                    vs {m.opponent}
                  </p>
                  <p class="mt-1 text-sm text-white/60">{m.dateLabel}</p>
                  {m.abemaUrl && (
                    <a
                      href={m.abemaUrl}
                      target="_blank"
                      rel="noopener"
                      class="mt-3 inline-flex items-center justify-center gap-1.5 rounded-sm border border-murash-red/50 px-3 py-2 font-display text-xs font-semibold tracking-wide text-murash-red-light transition-colors hover:bg-murash-red hover:text-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-murash-red focus-visible:ring-offset-2 focus-visible:ring-offset-murash-black"
                    >
                      ABEMAで無料生中継
                      <span aria-hidden="true">↗</span>
                    </a>
                  )}
                </li>
              ))}
            </ul>
          )
        }

        <div class="mt-8 flex justify-center">
          <a
            href={NEXT_MATCH.detailUrl}
            class="inline-flex items-center gap-2 rounded-sm border border-white/20 px-5 py-2.5 font-display text-sm font-semibold tracking-wide text-white transition-colors hover:border-white/40 hover:bg-white/5 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-murash-red focus-visible:ring-offset-2 focus-visible:ring-offset-murash-black"
          >
            大会情報を見る
            <span aria-hidden="true">→</span>
          </a>
        </div>

        <p
          class="mt-6 text-center font-display text-sm font-semibold tracking-wide text-murash-red/85"
        >
          ── ムラッシュFCの次の戦いを見逃すな ──
        </p>
      </div>
    </div>
  </section>

  <!-- コンテンツ一覧 -->
  <section class="mx-auto max-w-6xl px-4 py-24 sm:px-6 sm:py-28">
    <div>
      <p class="font-display text-sm font-semibold tracking-[0.3em] text-murash-red">CONTENTS</p>
      <h2 class="mt-2 font-display text-3xl font-bold tracking-tight text-white sm:text-4xl">
        コンテンツ一覧
      </h2>
      <p class="mt-3 max-w-xl text-sm text-white/50">
        ムラッシュFCのすべてを、ファン目線でアーカイブ。
      </p>
    </div>

    <ul class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {
        sections.map((s) => (
          <li>
            <a
              href={s.href}
              class="content-card group flex h-full flex-col rounded-md border border-white/10 bg-murash-charcoal p-5 transition-all duration-200 hover:-translate-y-0.5 hover:border-murash-red/60"
            >
              <span class="font-display text-[11px] font-bold tracking-[0.3em] text-murash-red">
                {s.no}
              </span>
              <h3 class="mt-2 font-display text-lg font-bold tracking-tight text-white transition-colors group-hover:text-murash-red sm:text-xl">
                {s.label}
              </h3>
              <p class="mt-1.5 line-clamp-2 text-xs leading-relaxed text-white/55 sm:text-sm">
                {s.sub}
              </p>
              <span class="mt-4 inline-flex items-center gap-1 font-display text-xs font-semibold tracking-wide text-white/40 transition-colors group-hover:text-murash-red">
                <span aria-hidden="true" class="transition-transform group-hover:translate-x-0.5">
                  →
                </span>
                詳しく見る
              </span>
            </a>
          </li>
        ))
      }
    </ul>
  </section>

  <!-- 特別フィーチャー：加藤純一の覚悟（コンテンツ一覧と Visual Timeline の間） -->
  <section
    class="relative overflow-hidden border-y border-white/10 bg-gradient-to-br from-murash-black via-murash-charcoal to-murash-black py-20 sm:py-28"
  >
    <!-- 背景の赤グロー演出 -->
    <div class="pointer-events-none absolute inset-0 -z-0">
      <div class="absolute -left-24 top-1/3 h-72 w-72 rounded-full bg-murash-red/15 blur-3xl"></div>
      <div class="absolute -right-24 bottom-0 h-64 w-64 rounded-full bg-murash-red/10 blur-3xl"></div>
    </div>

    <div class="relative mx-auto max-w-5xl px-4 text-center sm:px-6">
      <!-- 小さなラベル -->
      <p class="font-display text-sm font-bold tracking-[0.4em] text-murash-red">
        SPECIAL FEATURE
      </p>

      <!-- 英語サブタイトル -->
      <p class="mt-8 font-display text-xs font-semibold tracking-[0.35em] text-white/50">
        THE STORY OF JUNICHI KATO
      </p>

      <!-- 大きなタイトル（明朝） -->
      <h2
        class="mt-3 text-4xl font-bold tracking-tight text-white sm:text-5xl lg:text-6xl"
        style="font-family: var(--font-section-jp); font-weight: 700;"
      >
        加藤純一の覚悟
      </h2>

      <!-- サブタイトル -->
      <p class="mt-4 text-base text-white/70 sm:text-lg">
        ── キングスリーグに懸ける、終わらない挑戦
      </p>

      <!-- 引用ブロック -->
      <blockquote class="mt-10 inline-block border-l-2 border-murash-red pl-5 text-left">
        <p
          class="text-2xl text-white sm:text-3xl"
          style="font-family: var(--font-section-jp); font-weight: 700;"
        >
          「俺を信じろ」
        </p>
        <cite class="mt-2 block text-sm not-italic text-white/50">
          ── 加藤純一
        </cite>
      </blockquote>

      <!-- 紹介文 -->
      <p class="mx-auto mt-8 max-w-2xl text-sm leading-relaxed text-white/65 sm:text-base">
        ピケからの招待、衝撃の出会い、7連敗の悔しさ──。<br class="hidden sm:block" />
        ムラッシュFCのオーナーがキングスリーグに懸ける、覚悟と執念の物語。
      </p>

      <!-- CTA -->
      <a
        href="/junichi-kato"
        class="feature-cta mt-10 inline-flex items-center gap-2 rounded-sm bg-murash-red px-8 py-4 font-display text-base font-bold tracking-wide text-white shadow-lg shadow-black/40 transition-all hover:bg-murash-red-dark hover:scale-105"
      >
        ストーリーを読む
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </section>

  <!-- ビジュアル年表 -->
  <section class="border-y border-white/10 bg-murash-black">
    <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 sm:py-20">
      <div>
        <p class="font-display text-sm font-semibold tracking-[0.3em] text-murash-red">
          VISUAL TIMELINE
        </p>
        <h2 class="mt-2 font-display text-3xl font-bold tracking-tight text-white sm:text-4xl">
          ビジュアルで辿る軌跡
        </h2>
        <p class="mt-3 max-w-xl text-sm text-white/50">
          4大会＋再スタート編の歩みを、AI生成のインフォグラフィックで一望。
        </p>
      </div>

      <!-- モバイル/タブレット：横スクロール、lg+：5カラムグリッド -->
      <ul class="mt-10 flex snap-x snap-mandatory gap-4 overflow-x-auto pb-4 lg:grid lg:grid-cols-5 lg:gap-4 lg:overflow-visible lg:pb-0">
        {
          visualTimeline.map((v) => (
            <li class="snap-start shrink-0 basis-[78%] sm:basis-[46%] md:basis-[31%] lg:basis-auto">
              <a
                href={v.href}
                class="group flex h-full flex-col overflow-hidden rounded-md border border-white/10 bg-murash-charcoal transition-colors hover:border-murash-red/50"
              >
                <div class="relative aspect-video overflow-hidden bg-black">
                  <img
                    src={v.image}
                    alt={`${v.label} ビジュアルサマリー（インフォグラフィック）`}
                    width={v.w}
                    height={v.h}
                    loading="lazy"
                    decoding="async"
                    class:list={[
                      "h-full w-full transition-transform duration-500",
                      v.contain ? "object-contain" : "object-cover group-hover:scale-105",
                    ]}
                  />
                </div>
                <div class="p-3 sm:p-4">
                  <p class="font-display text-[10px] font-semibold tracking-[0.25em] text-murash-red">
                    {v.no}
                  </p>
                  <p class="mt-1 font-display text-sm font-bold tracking-tight text-white sm:text-base">
                    {v.label}
                  </p>
                </div>
              </a>
            </li>
          ))
        }
      </ul>

      <aside
        class="mt-6 rounded-md border border-murash-red/30 bg-black/60 px-4 py-3 sm:px-5 sm:py-4"
      >
        <p
          class="font-display text-sm font-bold tracking-wide text-white/90 sm:text-base"
        >
          ⚠️ これらの画像はAIで生成したイメージです
        </p>
        <p class="mt-2 text-xs leading-relaxed text-white/65 sm:text-sm">
          人物のビジュアル・表情・特徴は実在の選手・関係者と異なります。雰囲気を伝えるためのファンアートとしてお楽しみください。一部の漢字表記・スコア等にも揺れがある場合があります。
        </p>
      </aside>
    </div>
  </section>

  <!-- 大会戦績ハイライト -->
  <section class="border-y border-white/10 bg-murash-charcoal/40">
    <div class="mx-auto max-w-6xl px-4 py-20 sm:px-6">
      <div class="flex flex-wrap items-end justify-between gap-4">
        <div>
          <p class="font-display text-sm font-semibold tracking-[0.3em] text-murash-red">
            TOURNAMENT RESULTS
          </p>
          <h2 class="mt-2 font-display text-3xl font-bold tracking-tight text-white sm:text-4xl">
            大会戦績
          </h2>
        </div>
        <a
          href="/tournaments"
          class="group inline-flex items-center gap-1.5 font-display text-sm font-semibold tracking-wide text-white/60 transition-colors hover:text-murash-red"
        >
          詳しく見る
          <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">→</span>
        </a>
      </div>

      <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {
          results.map((r) => (
            <a
              href={r.hasDetail ? `/tournaments/${r.urlSlug}` : "/tournaments"}
              class="group relative flex flex-col overflow-hidden rounded-md border border-white/10 bg-murash-black p-6 transition-colors hover:border-murash-red/50"
            >
              <span
                aria-hidden="true"
                class="pointer-events-none absolute -right-3 -top-6 font-display text-8xl font-bold leading-none text-white/[0.04] transition-colors group-hover:text-murash-red/10"
              >
                {r.index}
              </span>

              <div class="relative flex items-center gap-2">
                <span class="rounded-sm bg-murash-red px-2 py-0.5 font-display text-xs font-bold tracking-wide text-white">
                  {r.no}
                </span>
                <span class="font-display text-xs font-semibold tracking-wider text-white/40">
                  {r.ym}
                </span>
                {r.upcoming && (
                  <span class="rounded-sm border border-murash-red/40 bg-murash-red/10 px-1.5 py-0.5 font-display text-[10px] font-bold tracking-widest text-murash-red-light">
                    開催予定
                  </span>
                )}
              </div>

              <h3 class="relative mt-4 font-display text-xl font-bold tracking-tight text-white">
                {r.name}
              </h3>

              <div class="relative mt-auto pt-6">
                {r.record && (
                  <p class="font-display text-3xl font-bold tracking-tight text-murash-red">
                    {r.record}
                  </p>
                )}
                <p class="mt-1 text-sm text-white/60">{r.result}</p>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- 注意書きバナー -->
  <section class="mx-auto max-w-6xl px-4 py-20 sm:px-6">
    <div class="rounded-md border border-murash-red/30 bg-murash-red/5 p-6">
      <p class="text-sm leading-relaxed text-white/70">
        <span class="font-semibold text-murash-red">⚠ 非公認サイトです。</span>
        当サイトはファンが個人的に運営しているもので、ムラッシュFC・キングスリーグ公式とは一切関係ありません。
        公式情報は
        <a
          href="https://www.murash.win/"
          target="_blank"
          rel="noopener noreferrer"
          class="text-murash-red underline-offset-2 hover:underline">https://www.murash.win/</a
        >
        をご確認ください。
      </p>
    </div>
  </section>
</Layout>

<style>
  /*
   * NEXT MATCH 見出しの改行位置制御。
   * keep-all で CJK の任意改行（「エキシビジ／ョン」のような語中改行）を止め、
   * マークアップ側の <wbr> を入れた意味の切れ目でだけ折り返させる。
   * break-word は保険：チャンク単体が幅に収まらない極端に狭い画面でのみ、
   * 従来どおり任意位置で折ってはみ出しを防ぐ。
   */
  .next-match-title {
    word-break: keep-all;
    overflow-wrap: break-word;
  }

  .content-card:hover {
    box-shadow: 0 8px 22px -12px rgba(230, 0, 18, 0.45);
  }
  @media (prefers-reduced-motion: reduce) {
    .content-card,
    .feature-cta {
      transition: none !important;
      transform: none !important;
    }
  }

  @keyframes gridDrift {
    0% {
      background-position: 0px 0px;
    }
    100% {
      background-position: 48px 48px;
    }
  }
  @keyframes glowPulse {
    0%,
    100% {
      text-shadow: 0 0 18px rgba(230, 0, 18, 0.25);
    }
    50% {
      text-shadow:
        0 0 34px rgba(230, 0, 18, 0.55),
        0 0 10px rgba(230, 0, 18, 0.35);
    }
  }
  @keyframes bounceDown {
    0%,
    100% {
      transform: translateY(0);
      opacity: 0.55;
    }
    50% {
      transform: translateY(8px);
      opacity: 1;
    }
  }
  @keyframes countdownBreath {
    0%,
    100% {
      box-shadow:
        0 0 30px -8px rgba(230, 0, 18, 0.25),
        inset 0 0 0 1px rgba(230, 0, 18, 0.05);
    }
    50% {
      box-shadow:
        0 0 60px -8px rgba(230, 0, 18, 0.55),
        inset 0 0 0 1px rgba(230, 0, 18, 0.2);
    }
  }
  @keyframes cdTick {
    0% {
      opacity: 0.4;
      transform: translateY(-4px);
    }
    100% {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .grid-bg {
    animation: gridDrift 18s linear infinite;
  }
  .glow-text {
    animation: glowPulse 4.5s ease-in-out infinite;
  }
  .scroll-arrow {
    animation: bounceDown 1.8s ease-in-out infinite;
  }
  .countdown-pulse {
    animation: countdownBreath 3.5s ease-in-out infinite;
  }
  .cd-num.cd-tick {
    animation: cdTick 0.35s ease-out;
  }

  @media (prefers-reduced-motion: reduce) {
    .grid-bg,
    .glow-text,
    .scroll-arrow,
    .countdown-pulse,
    .cd-num.cd-tick {
      animation: none;
    }
  }
</style>

<script>
  interface MatchData {
    no: string;
    opponent: string;
    iso: string;
  }

  const el = document.getElementById("countdown");
  if (el instanceof HTMLElement && el.dataset.matches) {
    const matches: MatchData[] = JSON.parse(el.dataset.matches);
    // 日時順に並べておく（データ側の順序に依存しない）
    matches.sort(
      (a, b) => new Date(a.iso).getTime() - new Date(b.iso).getTime(),
    );

    const targetLabel = document.getElementById("cd-target-label");
    const matchList = document.getElementById("match-list");
    const items = matchList
      ? Array.from(
          matchList.querySelectorAll<HTMLElement>("[data-match-item]"),
        )
      : [];

    /** 現在時刻より後で最も近い試合。全試合終了後は null */
    const nextMatch = (): MatchData | null =>
      matches.find((m) => new Date(m.iso).getTime() > Date.now()) ?? null;

    /** 次戦カードの強調を更新 */
    const markNext = (m: MatchData | null) => {
      items.forEach((li) => {
        const isNext = !!m && li.dataset.iso === m.iso;
        li.classList.toggle("border-murash-red/60", isNext);
        li.classList.toggle("bg-murash-red/5", isNext);
        li.classList.toggle("border-white/10", !isNext);
        li.classList.toggle("bg-black/45", !isNext);
        const badge = li.querySelector<HTMLElement>("[data-next-badge]");
        if (badge) badge.classList.toggle("hidden", !isNext);
      });
    };

    const dd = document.getElementById("cd-days");
    const hh = document.getElementById("cd-hours");
    const mm = document.getElementById("cd-mins");
    const ss = document.getElementById("cd-secs");
    const note = document.getElementById("cd-note");
    const pad = (n: number) => String(n).padStart(2, "0");

    // 数字が変わったときだけ「cd-tick」をフラッシュしてフェードイン
    const setNum = (
      target: HTMLElement | null,
      value: string,
      animate: boolean,
    ) => {
      if (!target || target.textContent === value) return;
      target.textContent = value;
      if (!animate) return;
      target.classList.remove("cd-tick");
      // 強制リフロー：同名アニメを連続トリガするため
      void target.offsetWidth;
      target.classList.add("cd-tick");
    };

    let timer: ReturnType<typeof setInterval>;
    let currentIso: string | null = null;

    const tick = () => {
      const m = nextMatch();

      // 全試合終了：ゼロ表示のまま「エキシビション終了」を案内し、詳細ページへ誘導
      if (!m) {
        setNum(dd, "0", false);
        setNum(hh, "00", false);
        setNum(mm, "00", false);
        setNum(ss, "00", false);
        if (targetLabel) targetLabel.textContent = "エキシビション終了";
        if (note) {
          note.textContent =
            "全3試合が終了しました。結果は大会情報ページをご覧ください。";
          note.classList.remove("hidden");
        }
        markNext(null);
        clearInterval(timer);
        return;
      }

      // 対象試合が繰り上がったら表示を更新
      if (m.iso !== currentIso) {
        currentIso = m.iso;
        if (targetLabel) {
          targetLabel.textContent = `${m.no} vs ${m.opponent}`;
        }
        markNext(m);
      }

      const diff = new Date(m.iso).getTime() - Date.now();
      const s = Math.floor(diff / 1000);
      // 日・時間・分はアニメ、秒は静かに更新（うるさくならないように）
      setNum(dd, String(Math.floor(s / 86400)), true);
      setNum(hh, pad(Math.floor((s % 86400) / 3600)), true);
      setNum(mm, pad(Math.floor((s % 3600) / 60)), true);
      setNum(ss, pad(s % 60), false);
    };

    tick();
    timer = setInterval(tick, 1000);
  }
</script>
