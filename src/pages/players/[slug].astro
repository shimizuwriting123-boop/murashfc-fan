---
import Layout from "../../layouts/Layout.astro";
import {
  players,
  PHASE_SHORT_LABEL,
  ROLE_LABEL,
  TOURNAMENTS,
  type DominantFoot,
  type Player,
} from "../../data/players";
import { renderRichText } from "../../utils/autoLink";

export function getStaticPaths() {
  return players.map((player) => ({
    params: { slug: player.slug },
    props: { player },
  }));
}

interface Props {
  player: Player;
}

const { player } = Astro.props;

const FOOT_LABEL: Record<DominantFoot, string> = {
  right: "右",
  left: "左",
  both: "両",
};

// 基本情報（存在する項目のみ表示。past は背番号を出さない）。
// 順序：ポジション → 背番号 → ニックネーム → 生年月日 → 出身 → 身長 → 体重 → 利き足
const profile = [
  { label: "ポジション", value: player.position },
  ...(player.status !== "past" && player.number !== undefined
    ? [{ label: "背番号", value: `No.${player.number}` }]
    : []),
  ...(player.nickname ? [{ label: "ニックネーム", value: player.nickname }] : []),
  ...(player.birthdate ? [{ label: "生年月日", value: player.birthdate }] : []),
  ...(player.hometown ? [{ label: "出身", value: player.hometown }] : []),
  ...(player.height ? [{ label: "身長", value: player.height }] : []),
  ...(player.weight ? [{ label: "体重", value: player.weight }] : []),
  ...(player.dominantFoot
    ? [{ label: "利き足", value: FOOT_LABEL[player.dominantFoot] }]
    : []),
];

// role がある場合は大バッジで表示するので、ヘッダーの小バッジは出さない（重複回避）
const hasRole = !!player.role;
const statusBadge = hasRole
  ? null
  : player.status === "pending"
    ? "準備中"
    : player.status === "past"
      ? "歴代メンバー"
      : player.status === "staff"
        ? "スタッフ"
        : null;

const SELF_URL = `/players/${player.slug}`;
const hasCareer = !!(player.career && player.career.length > 0);
const hasKakitani = !!player.kakitaniComment;
const hasMessage = !!player.playerMessage;
// kakitaniComment と feature が完全一致する場合は feature を出さない（重複回避）
const hasFeature =
  !!player.feature && player.feature !== player.kakitaniComment;
const hasTournaments = !!(player.tournaments && player.tournaments.length > 0);
const hasHistory = !!(
  player.tournamentHistory && player.tournamentHistory.length > 0
);
const hasSocial = !!(player.instagramUrl || player.xUrl);
// 公式サイトから引用したフィールドが含まれているか
const hasOfficialData = hasKakitani || hasMessage || hasSocial;
// 詳細データが何も無い pending のみ「準備中です」枠を表示
const showPendingNote =
  player.status === "pending" &&
  !hasCareer &&
  !hasFeature &&
  !hasKakitani &&
  !hasMessage;
---

<Layout
  title={`${player.name}${
    player.number !== undefined ? `（背番号${player.number}）` : ""
  } | 選手名鑑 | ムラッシュFC ファンサイト（非公認）`}
  description={`ムラッシュFC ${player.position} ${player.name}（${player.nameEn}）のプロフィール。`}
>
  <!-- プロフィールヘッダー -->
  <section class="relative overflow-hidden border-b border-white/10">
    <div class="absolute inset-0 -z-10">
      <div class="absolute inset-0 bg-gradient-to-br from-murash-charcoal via-murash-black to-black"></div>
      <div class="absolute -right-20 -top-24 h-80 w-80 rounded-full bg-murash-red/20 blur-3xl"></div>
    </div>

    {
      player.number !== undefined && player.status !== "past" && (
        <span
          aria-hidden="true"
          class="pointer-events-none absolute -right-4 top-1/2 -translate-y-1/2 select-none font-display text-[12rem] font-bold leading-none text-white/[0.04] sm:text-[18rem]"
        >
          {player.number}
        </span>
      )
    }

    <div class="relative mx-auto max-w-3xl px-4 py-12 sm:px-6 sm:py-16">
      <a
        href="/players"
        class="inline-flex items-center gap-1.5 text-sm text-white/50 transition-colors hover:text-white"
      >
        <span aria-hidden="true">←</span> 選手名鑑へ戻る
      </a>

      <div class="mt-8 flex flex-wrap items-center gap-3">
        <span
          class="rounded-sm bg-murash-red px-2.5 py-1 font-display text-sm font-bold tracking-wide text-white"
        >
          {player.position}
        </span>
        {
          hasRole && (
            <span class="rounded-sm border border-murash-red bg-murash-red/15 px-3 py-1 font-display text-sm font-bold tracking-wider text-murash-red">
              {player.role}
            </span>
          )
        }
        {
          player.number !== undefined && player.status !== "past" && (
            <span class="font-display text-sm font-semibold tracking-wider text-white/40">
              No.{player.number}
            </span>
          )
        }
        {
          statusBadge && (
            <span class="rounded-sm border border-white/20 bg-white/5 px-2 py-0.5 text-xs font-semibold text-white/60">
              {statusBadge}
            </span>
          )
        }
      </div>

      <h1
        class="mt-4 font-display text-4xl font-bold tracking-tight text-white sm:text-6xl"
      >
        {player.name}
      </h1>
      <p
        class="mt-2 font-display text-base font-semibold tracking-[0.2em] text-murash-red"
      >
        {player.nameEn}
      </p>
      {
        player.nickname && (
          <p class="mt-3 text-sm text-white/60">
            ニックネーム：<span class="text-white/90">{player.nickname}</span>
          </p>
        )
      }
    </div>
  </section>

  <!-- 本文 -->
  <div class="mx-auto max-w-3xl px-4 py-14 sm:px-6">
    <!-- 基本情報 -->
    <section>
      <h2 class="font-display text-xl font-bold tracking-tight text-white sm:text-2xl">
        基本情報
      </h2>
      <div class="mt-2 h-px w-full bg-gradient-to-r from-murash-red/60 to-transparent"></div>
      <dl class="mt-5 grid gap-3 sm:grid-cols-2">
        {
          profile.map((row) => (
            <div class="flex gap-3 rounded-md border border-white/10 bg-murash-charcoal px-4 py-3">
              <dt class="w-24 shrink-0 font-display text-xs font-semibold tracking-wider text-white/40">
                {row.label}
              </dt>
              <dd class="text-sm text-[#e5e5e5]">{row.value}</dd>
            </div>
          ))
        }
      </dl>
    </section>

    {/* 大会別の役割・背番号（tournamentHistory がある場合はテーブル、なければ従来の出場大会一覧） */}
    {
      hasHistory ? (
        <section class="mt-12">
          <h2 class="font-display text-xl font-bold tracking-tight text-white sm:text-2xl">
            大会別の役割・背番号
          </h2>
          <div class="mt-2 h-px w-full bg-gradient-to-r from-murash-red/60 to-transparent" />
          <div class="mt-5 overflow-hidden rounded-md border border-white/10">
            <table class="w-full border-collapse text-left text-sm sm:text-base">
              <thead class="bg-murash-charcoal text-xs font-semibold tracking-wider text-white/50 sm:text-sm">
                <tr>
                  <th class="px-4 py-3 font-display font-bold">大会</th>
                  <th class="px-4 py-3 font-display font-bold">役割</th>
                  <th class="px-4 py-3 text-right font-display font-bold">背番号</th>
                </tr>
              </thead>
              <tbody>
                {player.tournamentHistory!.map((h) => {
                  const isTournament = h.tournament !== "rebirth";
                  const roleText = h.subRole ?? ROLE_LABEL[h.role];
                  const fullRole = h.position
                    ? `${roleText}（${h.position}）`
                    : roleText;
                  const phaseLabel = PHASE_SHORT_LABEL[h.tournament];
                  const linkHref = isTournament
                    ? `/tournaments/${
                        h.tournament === "mexico"
                          ? "mexico-2024"
                          : h.tournament === "italy"
                            ? "italy-2025"
                            : h.tournament === "france"
                              ? "france-2025"
                              : "brazil-2026"
                      }`
                    : "/rebirth";
                  return (
                    <tr class="border-t border-white/10 transition-colors hover:bg-white/[0.03]">
                      <td class="px-4 py-3 align-middle">
                        <a
                          href={linkHref}
                          class="inline-flex items-center gap-2 font-display font-bold tracking-tight text-white hover:text-murash-red"
                        >
                          {isTournament ? `${phaseLabel}大会` : "再スタート編"}
                          <span aria-hidden="true" class="text-murash-red">
                            →
                          </span>
                        </a>
                      </td>
                      <td class="px-4 py-3 align-middle text-[#e5e5e5]">{fullRole}</td>
                      <td class="px-4 py-3 text-right align-middle font-display font-semibold text-white/80">
                        {h.jerseyNumber !== undefined ? `#${h.jerseyNumber}` : "—"}
                      </td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>
        </section>
      ) : hasTournaments ? (
        <section class="mt-12">
          <h2 class="font-display text-xl font-bold tracking-tight text-white sm:text-2xl">
            出場大会
          </h2>
          <div class="mt-2 h-px w-full bg-gradient-to-r from-murash-red/60 to-transparent" />
          <ul class="mt-5 space-y-3">
            {player.tournaments!.map((t) => {
              const info = TOURNAMENTS[t];
              return (
                <li>
                  <a
                    href="/tournaments"
                    class="group flex items-center justify-between rounded-md border border-white/10 bg-murash-charcoal px-5 py-4 transition-colors hover:border-murash-red/50"
                  >
                    <span class="flex items-center gap-3">
                      <span class="rounded-sm bg-murash-red px-2 py-0.5 font-display text-xs font-bold tracking-wide text-white">
                        {info.no}
                      </span>
                      <span class="font-display text-base font-bold tracking-tight text-white">
                        {info.short}大会
                      </span>
                    </span>
                    <span
                      aria-hidden="true"
                      class="text-murash-red transition-transform group-hover:translate-x-1"
                    >
                      →
                    </span>
                  </a>
                </li>
              );
            })}
          </ul>
        </section>
      ) : null
    }

    <!-- 経歴 -->
    {
      hasCareer && (
        <section class="mt-12">
          <h2 class="font-display text-xl font-bold tracking-tight text-white sm:text-2xl">
            経歴
          </h2>
          <div class="mt-2 h-px w-full bg-gradient-to-r from-murash-red/60 to-transparent" />
          <ol class="relative mt-6">
            <span
              aria-hidden="true"
              class="pointer-events-none absolute bottom-2 left-[5px] top-2 w-px bg-gradient-to-b from-murash-red/70 via-white/15 to-transparent"
            />
            {player.career!.map((step) => (
              <li class="relative flex items-start gap-4 pb-6 last:pb-0">
                <span
                  aria-hidden="true"
                  class="relative z-10 mt-1.5 h-2.5 w-2.5 shrink-0 rounded-full bg-murash-red ring-4 ring-murash-black"
                />
                <span class="text-sm leading-[1.7] text-[#e5e5e5] sm:text-base">{step}</span>
              </li>
            ))}
          </ol>
        </section>
      )
    }

    <!-- 柿谷オーナー評 -->
    {
      hasKakitani && (
        <section class="mt-12">
          <h2 class="font-display text-xl font-bold tracking-tight text-white sm:text-2xl">
            柿谷オーナー評
          </h2>
          <div class="mt-2 h-px w-full bg-gradient-to-r from-murash-red/60 to-transparent" />
          <figure class="mt-5 rounded-md border-l-2 border-murash-red/60 bg-murash-charcoal p-5 sm:p-6">
            <blockquote class="text-sm leading-[1.95] text-[#e5e5e5] sm:text-base">
              <span class="select-none font-display text-2xl leading-none text-murash-red/60">
                「
              </span>
              <span
                set:html={renderRichText(player.kakitaniComment!, {
                  excludeUrl: SELF_URL,
                })}
              />
              <span class="select-none font-display text-2xl leading-none text-murash-red/60">
                」
              </span>
            </blockquote>
            <figcaption class="mt-3 font-display text-xs font-semibold tracking-[0.2em] text-white/40">
              ── 柿谷曜一朗（ダブルオーナー）
            </figcaption>
          </figure>
        </section>
      )
    }

    <!-- 本人メッセージ -->
    {
      hasMessage && (
        <section class="mt-12">
          <h2 class="font-display text-xl font-bold tracking-tight text-white sm:text-2xl">
            本人メッセージ
          </h2>
          <div class="mt-2 h-px w-full bg-gradient-to-r from-murash-red/60 to-transparent" />
          <figure class="mt-5 rounded-md border border-white/10 bg-gradient-to-br from-murash-red/[0.06] to-murash-charcoal p-5 sm:p-6">
            <blockquote
              class="text-sm leading-[1.95] text-[#e5e5e5] sm:text-base"
              set:html={renderRichText(player.playerMessage!, {
                excludeUrl: SELF_URL,
              })}
            />
            <figcaption class="mt-3 font-display text-xs font-semibold tracking-[0.2em] text-white/40">
              ── {player.name}
            </figcaption>
          </figure>
        </section>
      )
    }

    <!-- 特徴 -->
    {
      hasFeature && (
        <section class="mt-12">
          <h2 class="font-display text-xl font-bold tracking-tight text-white sm:text-2xl">
            特徴
          </h2>
          <div class="mt-2 h-px w-full bg-gradient-to-r from-murash-red/60 to-transparent" />
          <p
            class="mt-5 rounded-md border-l-2 border-murash-red/50 bg-murash-charcoal p-5 text-sm leading-[1.9] text-[#e5e5e5] sm:text-base"
            set:html={renderRichText(player.feature!, { excludeUrl: SELF_URL })}
          />
        </section>
      )
    }

    <!-- SNS -->
    {
      hasSocial && (
        <section class="mt-12">
          <h2 class="font-display text-xl font-bold tracking-tight text-white sm:text-2xl">
            SNS
          </h2>
          <div class="mt-2 h-px w-full bg-gradient-to-r from-murash-red/60 to-transparent" />
          <div class="mt-5 flex flex-wrap gap-3">
            {player.instagramUrl && (
              <a
                href={player.instagramUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="group inline-flex items-center gap-2.5 rounded-md border border-white/10 bg-murash-charcoal px-4 py-2.5 transition-all hover:-translate-y-0.5 hover:border-murash-red/60"
              >
                <svg
                  aria-hidden="true"
                  viewBox="0 0 24 24"
                  class="h-5 w-5 fill-current text-white/70 transition-colors group-hover:text-murash-red"
                >
                  <path d="M12 2.2c3.2 0 3.6 0 4.85.07 1.17.05 1.8.25 2.23.41.56.22.96.48 1.38.9.42.42.68.82.9 1.38.16.42.36 1.06.41 2.22.06 1.27.07 1.65.07 4.85s0 3.59-.07 4.85c-.05 1.17-.25 1.8-.41 2.23-.22.56-.48.96-.9 1.38-.42.42-.82.68-1.38.9-.42.16-1.06.36-2.22.41-1.27.06-1.65.07-4.85.07s-3.59 0-4.85-.07c-1.17-.05-1.8-.25-2.23-.41a3.7 3.7 0 0 1-1.38-.9 3.7 3.7 0 0 1-.9-1.38c-.16-.42-.36-1.06-.41-2.22C2.2 15.6 2.2 15.2 2.2 12s0-3.59.07-4.85c.05-1.17.25-1.8.41-2.23.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.42-.16 1.06-.36 2.22-.41C8.41 2.2 8.8 2.2 12 2.2zm0 1.8c-3.15 0-3.51 0-4.74.06-1.07.05-1.65.23-2.04.38-.51.2-.88.44-1.27.83-.39.39-.63.76-.83 1.27-.15.39-.33.97-.38 2.04C2.68 8.49 2.7 8.85 2.7 12s0 3.51.06 4.74c.05 1.07.23 1.65.38 2.04.2.51.44.88.83 1.27.39.39.76.63 1.27.83.39.15.97.33 2.04.38 1.23.06 1.59.06 4.74.06s3.51 0 4.74-.06c1.07-.05 1.65-.23 2.04-.38.51-.2.88-.44 1.27-.83.39-.39.63-.76.83-1.27.15-.39.33-.97.38-2.04.06-1.23.06-1.59.06-4.74s0-3.51-.06-4.74c-.05-1.07-.23-1.65-.38-2.04a3.4 3.4 0 0 0-.83-1.27 3.4 3.4 0 0 0-1.27-.83c-.39-.15-.97-.33-2.04-.38C15.51 4 15.15 4 12 4zm0 3.06A4.94 4.94 0 1 1 7.06 12 4.95 4.95 0 0 1 12 7.06zm0 8.14A3.2 3.2 0 1 0 8.8 12a3.2 3.2 0 0 0 3.2 3.2zm6.3-8.34a1.15 1.15 0 1 1-1.15-1.15 1.15 1.15 0 0 1 1.15 1.15z" />
                </svg>
                <span class="text-sm font-medium text-white">Instagram</span>
              </a>
            )}
            {player.xUrl && (
              <a
                href={player.xUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="group inline-flex items-center gap-2.5 rounded-md border border-white/10 bg-murash-charcoal px-4 py-2.5 transition-all hover:-translate-y-0.5 hover:border-murash-red/60"
              >
                <svg
                  aria-hidden="true"
                  viewBox="0 0 24 24"
                  class="h-4 w-4 fill-current text-white/70 transition-colors group-hover:text-murash-red"
                >
                  <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
                </svg>
                <span class="text-sm font-medium text-white">X (Twitter)</span>
              </a>
            )}
          </div>
        </section>
      )
    }

    <!-- 準備中（pending かつ詳細データなしの時だけ） -->
    {
      showPendingNote && (
        <section class="mt-12">
          <div class="rounded-md border border-dashed border-white/20 bg-white/5 p-10 text-center">
            <p class="font-display text-lg font-bold text-white/70">情報を準備中です</p>
            <p class="mt-2 text-sm text-white/40">
              この選手の詳細プロフィールは現在準備中です。続報をお待ちください。
            </p>
          </div>
        </section>
      )
    }

    <div class="mt-12 border-t border-white/10 pt-8">
      <a
        href="/players"
        class="inline-flex items-center gap-2 rounded-sm border border-white/20 px-6 py-3 font-display text-sm font-semibold tracking-wide text-white transition-colors hover:border-white/40 hover:bg-white/5"
      >
        <span aria-hidden="true">←</span> 選手名鑑へ戻る
      </a>
    </div>

    {
      hasOfficialData ? (
        <aside class="mt-8 rounded-md border border-white/10 bg-white/5 p-4 sm:p-5">
          <p class="text-xs leading-relaxed text-white/55 sm:text-sm">
            ※プロフィール情報の一部はムラッシュFC公式サイト（
            <a
              href={`https://www.murash.win/murashfc/players/${player.nameEn}`}
              target="_blank"
              rel="noopener noreferrer"
              class="text-white/70 underline-offset-2 hover:text-white hover:underline"
            >
              https://www.murash.win/murashfc/players/
            </a>
            ）から引用しています。
          </p>
        </aside>
      ) : player.researchedProfile ? (
        <aside class="mt-8 rounded-md border border-white/10 bg-white/5 p-4 sm:p-5">
          <p class="text-xs leading-relaxed text-white/55 sm:text-sm">
            ※プロフィール情報は本人公開情報、各クラブ公式発表、Wikipedia 等を参照しています。
          </p>
        </aside>
      ) : null
    }
  </div>
</Layout>
