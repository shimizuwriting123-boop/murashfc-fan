---
import Layout from "../../layouts/Layout.astro";
import {
  players,
  TOURNAMENTS,
  type Player,
  type Position,
  type TournamentSlug,
} from "../../data/players";

/**
 * 「現メンバー」判定：新生16名（confirmed）＋ 新体制スタッフ（staff かつ rebirth に
 * 参加しており、レベナンツ等の外部チーム役職ではない人物）。
 * 中井健介（status="staff" だが rebirth role が「レベナンツ監督」）は past 扱いになる。
 */
function isCurrentMember(p: Player): boolean {
  if (p.status === "confirmed") return true;
  if (p.status === "staff") {
    const rebirth = p.tournamentHistory?.find((h) => h.tournament === "rebirth");
    if (!rebirth) return false;
    // レベナンツは敵対チーム、新生ムラッシュFCの一員ではない
    if (rebirth.subRole?.includes("レベナンツ")) return false;
    return true;
  }
  return false;
}

/**
 * その選手が「関わった」大会 slug 集合を返す（大会フィルター用）。
 * 既存の tournaments と新規 tournamentHistory（rebirth を除く）を統合し、
 * スタッフ・コーチ・トレーナーも含めて大会フィルターに引っかかるようにする。
 */
function involvedTournaments(p: Player): Set<TournamentSlug> {
  const set = new Set<TournamentSlug>();
  for (const t of p.tournaments ?? []) set.add(t);
  for (const h of p.tournamentHistory ?? []) {
    if (h.tournament !== "rebirth") set.add(h.tournament);
  }
  return set;
}

// 現メンバー（選手＝confirmed、スタッフ＝rebirth参加）と歴代に分類
const currentMembers = players.filter(isCurrentMember);
const pastMembers = players.filter((p) => !isCurrentMember(p));

// 現メンバー：選手（背番号順）
const currentPlayers = currentMembers
  .filter((p) => p.status === "confirmed")
  .sort((a, b) => (a.number ?? 0) - (b.number ?? 0));

// 現メンバー：スタッフ（重要度順：ダブルオーナー → 監督 → コーチ → マネージャー）
const STAFF_ROLE_ORDER = ["ダブルオーナー", "監督", "コーチ", "マネージャー"];
const staffOrderIndex = (role?: string): number => {
  if (!role) return 99;
  const i = STAFF_ROLE_ORDER.indexOf(role);
  return i === -1 ? 99 : i;
};
const currentStaff = currentMembers
  .filter((p) => p.status === "staff")
  .sort((a, b) => staffOrderIndex(a.role) - staffOrderIndex(b.role));

// 大会フィルター用の全体集合（現メンバー → 歴代の順）
const allPlayersSorted = [...currentMembers, ...pastMembers];

// 選手セクション用のポジション別カウント（スタッフは除外）
const positionOrder: Position[] = ["GK", "DF", "MF", "FW"];
const countByPosition = positionOrder.map((pos) => ({
  pos,
  count: currentPlayers.filter((p) => p.position === pos).length,
}));

// 大会別カウント（チップに表示）。allPlayersSorted から involvedTournaments() で算出
const tournamentOrder: TournamentSlug[] = ["mexico", "italy", "france", "brazil"];
const tournamentCount = tournamentOrder.map((t) => ({
  t,
  count: allPlayersSorted.filter((p) => involvedTournaments(p).has(t)).length,
}));

// タブラベル件数
const currentTotal = currentMembers.length; // 20
const pastTotal = pastMembers.length; // 30
---

<Layout
  title="選手名鑑 | ムラッシュFC ファンサイト（非公認）"
  description="ムラッシュFCの現メンバーと歴代メンバーを一覧で紹介。背番号・ポジション・出場大会とあわせてチェックできます。"
>
  <!-- ページヘッダー -->
  <section class="relative overflow-hidden border-b border-white/10">
    <div class="absolute inset-0 -z-10">
      <div class="absolute inset-0 bg-gradient-to-br from-murash-charcoal via-murash-black to-black"></div>
      <div class="absolute -right-24 -top-24 h-72 w-72 rounded-full bg-murash-red/20 blur-3xl"></div>
    </div>

    <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
      <p class="font-display text-sm font-semibold tracking-[0.3em] text-murash-red">SQUAD</p>
      <h1 class="mt-3 font-display text-4xl font-bold tracking-tight text-white sm:text-5xl">
        選手名鑑
      </h1>
      <p class="mt-4 max-w-xl text-sm leading-relaxed text-white/60 sm:text-base">
        ムラッシュFCの現メンバー {currentTotal} 名と、これまでチームを支えた歴代メンバー・スタッフ {pastTotal}
         名をまとめています。
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-12 sm:px-6">
    <!-- フィルターモード見出し（URL ?filter=... 時にJSで表示） -->
    <div
      id="filter-mode-banner"
      class="rounded-md border border-murash-red/30 bg-murash-red/5 p-5 sm:p-6"
      hidden
    >
      <div class="flex flex-wrap items-center justify-between gap-3">
        <div>
          <p class="font-display text-xs font-semibold tracking-[0.3em] text-murash-red">
            FILTERED BY TOURNAMENT
          </p>
          <h2 class="mt-1 font-display text-2xl font-bold tracking-tight text-white sm:text-3xl">
            <span id="filter-mode-title">大会 出場メンバー</span>
            <span class="font-display text-base font-semibold text-white/50">
              （<span id="filter-mode-count">0</span>名）
            </span>
          </h2>
        </div>
        <button
          id="filter-clear"
          type="button"
          class="inline-flex items-center gap-1.5 rounded-sm border border-white/20 bg-white/5 px-3 py-2 font-display text-xs font-semibold tracking-wide text-white/70 transition-colors hover:border-murash-red/40 hover:text-white"
        >
          <span aria-hidden="true" class="text-base leading-none">×</span> フィルター解除
        </button>
      </div>
    </div>

    <!-- タブモード（クエリ無しのデフォルト表示） -->
    <div id="tab-mode-container">
      <div role="tablist" aria-label="メンバー切り替え" class="flex flex-wrap gap-2">
        <button
          type="button"
          role="tab"
          data-tab="current"
          aria-selected="true"
          class="tab-btn rounded-sm border border-white/10 bg-white/5 px-5 py-2.5 font-display text-sm font-semibold tracking-wide text-white/70 transition-colors hover:text-white"
        >
          現メンバー（{currentTotal}名）
        </button>
        <button
          type="button"
          role="tab"
          data-tab="past"
          aria-selected="false"
          class="tab-btn rounded-sm border border-white/10 bg-white/5 px-5 py-2.5 font-display text-sm font-semibold tracking-wide text-white/70 transition-colors hover:text-white"
        >
          歴代メンバー・スタッフ（{pastTotal}名）
        </button>
      </div>

      <!-- 現メンバータブ用：ポジション別サマリー（選手セクションのカウントのみ） -->
      <div id="current-toolbar" class="mt-8 flex flex-wrap gap-3">
        {
          countByPosition.map(({ pos, count }) => (
            <div class="flex items-center gap-2 rounded-sm border border-white/10 bg-white/5 px-3 py-1.5">
              <span class="font-display text-xs font-bold tracking-wide text-murash-red">
                {pos}
              </span>
              <span class="font-display text-sm font-semibold text-white">{count}</span>
            </div>
          ))
        }
      </div>

      <!-- 歴代メンバータブ用：大会フィルター（チップを押すと「全選手×大会」モードへ遷移） -->
      <div id="past-toolbar" class="mt-8 space-y-2.5" hidden>
        <p class="font-display text-[11px] font-semibold tracking-[0.25em] text-white/40">
          大会で絞り込む（現メンバー・歴代・スタッフを横断）
        </p>
        <div class="flex flex-wrap gap-2">
          <button
            type="button"
            data-filter="all"
            aria-pressed="true"
            class="filter-btn inline-flex items-center gap-1.5 rounded-sm border border-white/10 bg-white/5 px-3 py-1.5 font-display text-xs font-semibold tracking-wide text-white/60 transition-colors hover:text-white"
          >
            すべて
            <span class="text-white/40">{pastTotal}</span>
          </button>
          {
            tournamentCount.map(({ t, count }) => (
              <button
                type="button"
                data-filter={t}
                aria-pressed="false"
                class="filter-btn inline-flex items-center gap-1.5 rounded-sm border border-white/10 bg-white/5 px-3 py-1.5 font-display text-xs font-semibold tracking-wide text-white/60 transition-colors hover:text-white"
              >
                {TOURNAMENTS[t].short}
                <span class="text-white/40">{count}</span>
              </button>
            ))
          }
        </div>
      </div>
    </div>

    <!-- ============ 現メンバーモード：選手 + スタッフの2セクション構成 ============ -->
    <div id="current-mode">
      <!-- 選手セクション -->
      <section class="mt-10">
        <h2 class="section-heading">
          <span class="section-label-en">PLAYERS</span>
          <span class="section-title-jp flex flex-wrap items-baseline gap-x-3 text-2xl sm:text-3xl">
            選手
            <span class="font-display text-sm font-semibold text-white/40">{currentPlayers.length}名</span>
          </span>
        </h2>
        <div class="mt-3 h-px w-full bg-gradient-to-r from-murash-red/60 to-transparent"></div>
        <ul class="mt-6 grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-4">
          {
            currentPlayers.map((player) => (
              <li>
                <a
                  href={`/players/${player.slug}`}
                  class="group relative flex h-full flex-col overflow-hidden rounded-md border border-white/10 bg-murash-charcoal p-5 transition-colors hover:border-murash-red/50 hover:bg-murash-black"
                >
                  {player.number !== undefined && (
                    <span
                      aria-hidden="true"
                      class="pointer-events-none absolute -right-3 -top-5 font-display text-8xl font-bold leading-none text-white/[0.04] transition-colors group-hover:text-murash-red/10"
                    >
                      {player.number}
                    </span>
                  )}
                  <div class="relative flex items-center gap-2">
                    <span class="rounded-sm bg-murash-red px-2 py-0.5 font-display text-xs font-bold tracking-wide text-white">
                      {player.position}
                    </span>
                    {player.number !== undefined && (
                      <span class="font-display text-xs font-semibold tracking-wider text-white/40">
                        No.{player.number}
                      </span>
                    )}
                  </div>
                  <h2 class="relative mt-6 font-display text-lg font-bold tracking-tight text-white sm:text-xl">
                    {player.name}
                  </h2>
                  <span class="relative mt-auto inline-flex items-center gap-1 pt-4 font-display text-xs font-semibold tracking-wide text-white/40 transition-colors group-hover:text-murash-red">
                    詳細を見る
                    <span
                      aria-hidden="true"
                      class="transition-transform group-hover:translate-x-0.5"
                    >
                      →
                    </span>
                  </span>
                </a>
              </li>
            ))
          }
        </ul>
      </section>

      <!-- スタッフセクション -->
      <section class="mt-16">
        <h2 class="section-heading">
          <span class="section-label-en">COACHING STAFF</span>
          <span class="section-title-jp flex flex-wrap items-baseline gap-x-3 text-2xl sm:text-3xl">
            コーチング・スタッフ
            <span class="font-display text-sm font-semibold text-white/40">{currentStaff.length}名</span>
          </span>
        </h2>
        <div class="mt-3 h-px w-full bg-gradient-to-r from-murash-red/60 to-transparent"></div>
        <ul class="mt-6 grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-4">
          {
            currentStaff.map((player) => (
              <li>
                <a
                  href={`/players/${player.slug}`}
                  class="group relative flex h-full flex-col overflow-hidden rounded-md border border-white/10 bg-murash-charcoal p-5 transition-colors hover:border-murash-red/50 hover:bg-murash-black"
                >
                  <div class="relative flex items-center gap-2">
                    <span class="rounded-sm bg-murash-red px-2 py-0.5 font-display text-xs font-bold tracking-wide text-white">
                      {player.position}
                    </span>
                    <span class="ml-auto rounded-sm border border-murash-red/40 bg-murash-red/10 px-1.5 py-0.5 text-[10px] font-semibold text-murash-red">
                      {player.role ?? "スタッフ"}
                    </span>
                  </div>
                  <h2 class="relative mt-6 font-display text-lg font-bold tracking-tight text-white sm:text-xl">
                    {player.name}
                  </h2>
                  <span class="relative mt-auto inline-flex items-center gap-1 pt-4 font-display text-xs font-semibold tracking-wide text-white/40 transition-colors group-hover:text-murash-red">
                    詳細を見る
                    <span
                      aria-hidden="true"
                      class="transition-transform group-hover:translate-x-0.5"
                    >
                      →
                    </span>
                  </span>
                </a>
              </li>
            ))
          }
        </ul>
      </section>
    </div>

    <!-- ============ 歴代モード／大会フィルターモードの単一グリッド ============ -->
    <ul id="player-grid" class="mt-8 grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-4" hidden>
      {
        allPlayersSorted.map((player) => (
          <li
            data-status={player.status}
            data-membership={isCurrentMember(player) ? "current" : "past"}
            data-tournaments={[...involvedTournaments(player)].join(",")}
          >
            <a
              href={`/players/${player.slug}`}
              class="group relative flex h-full flex-col overflow-hidden rounded-md border border-white/10 bg-murash-charcoal p-5 transition-colors hover:border-murash-red/50 hover:bg-murash-black"
            >
              {player.status !== "past" && player.number !== undefined && (
                <span
                  aria-hidden="true"
                  class="pointer-events-none absolute -right-3 -top-5 font-display text-8xl font-bold leading-none text-white/[0.04] transition-colors group-hover:text-murash-red/10"
                >
                  {player.number}
                </span>
              )}

              <div class="relative flex items-center gap-2">
                <span class="rounded-sm bg-murash-red px-2 py-0.5 font-display text-xs font-bold tracking-wide text-white">
                  {player.position}
                </span>
                {player.status !== "past" && player.number !== undefined && (
                  <span class="font-display text-xs font-semibold tracking-wider text-white/40">
                    No.{player.number}
                  </span>
                )}
                {player.status === "pending" && (
                  <span class="ml-auto rounded-sm border border-white/20 bg-white/5 px-1.5 py-0.5 text-[10px] font-semibold text-white/50">
                    準備中
                  </span>
                )}
                {player.status === "past" && (
                  <span class="ml-auto rounded-sm border border-white/20 bg-white/5 px-1.5 py-0.5 text-[10px] font-semibold text-white/50">
                    歴代
                  </span>
                )}
                {player.status === "staff" && (
                  <span class="ml-auto rounded-sm border border-murash-red/40 bg-murash-red/10 px-1.5 py-0.5 text-[10px] font-semibold text-murash-red">
                    {player.role ?? "スタッフ"}
                  </span>
                )}
              </div>

              <h2 class="relative mt-6 font-display text-lg font-bold tracking-tight text-white sm:text-xl">
                {player.name}
              </h2>

              {player.status === "past" &&
                player.tournaments &&
                player.tournaments.length > 0 && (
                  <div class="relative mt-3 flex flex-wrap gap-1">
                    {player.tournaments.map((t) => (
                      <span class="rounded-sm border border-murash-red/30 bg-murash-red/5 px-1.5 py-0.5 text-[10px] font-semibold tracking-wide text-murash-red">
                        {TOURNAMENTS[t].short}
                      </span>
                    ))}
                  </div>
                )}

              <span class="relative mt-auto inline-flex items-center gap-1 pt-4 font-display text-xs font-semibold tracking-wide text-white/40 transition-colors group-hover:text-murash-red">
                詳細を見る
                <span
                  aria-hidden="true"
                  class="transition-transform group-hover:translate-x-0.5"
                >
                  →
                </span>
              </span>
            </a>
          </li>
        ))
      }
    </ul>
    <p id="empty-msg" class="mt-6 text-sm text-white/40" hidden>
      該当する選手が見つかりませんでした。
    </p>

    <!-- 注意書き -->
    <div class="mt-10 space-y-2 text-xs leading-relaxed text-white/40">
      <p>※本サイトの情報はファンが集めたものです。誤りがある場合は予告なく修正することがあります。</p>
      <p>※選手情報はファンが公開情報から収集したものです。誤りや更新事項があれば運営者までお知らせください。</p>
    </div>
  </section>
</Layout>

<style>
  .tab-btn[aria-selected="true"] {
    background-color: #e60012;
    border-color: transparent;
    color: #fff;
  }
  .filter-btn[aria-pressed="true"] {
    background-color: #e60012;
    border-color: transparent;
    color: #fff;
  }
  .filter-btn[aria-pressed="true"] span {
    color: rgba(255, 255, 255, 0.7);
  }
</style>

<script>
  const TOURNAMENT_LABEL: Record<string, string> = {
    mexico: "メキシコ",
    italy: "イタリア",
    france: "フランス",
    brazil: "ブラジル",
  };
  const VALID_TOURNAMENTS = ["mexico", "italy", "france", "brazil"];

  const tabContainer = document.getElementById("tab-mode-container");
  const filterBanner = document.getElementById("filter-mode-banner");
  const filterTitle = document.getElementById("filter-mode-title");
  const filterCount = document.getElementById("filter-mode-count");
  const filterClear = document.getElementById("filter-clear");
  const currentToolbar = document.getElementById("current-toolbar");
  const pastToolbar = document.getElementById("past-toolbar");
  const currentMode = document.getElementById("current-mode");
  const grid = document.getElementById("player-grid");
  const empty = document.getElementById("empty-msg");
  const items = grid
    ? Array.from(grid.querySelectorAll<HTMLLIElement>("li"))
    : [];
  const tabBtns = document.querySelectorAll<HTMLButtonElement>("[data-tab]");
  const filterBtns = document.querySelectorAll<HTMLButtonElement>("[data-filter]");

  // ステート
  let currentTab: "current" | "past" = "current";
  // 大会フィルターモードに入る直前のタブ。解除時にここへ戻す。
  let savedTabBeforeFilter: "current" | "past" | null = null;

  function tournamentsOf(li: HTMLLIElement) {
    return (li.dataset.tournaments ?? "").split(",").filter(Boolean);
  }

  function apply() {
    const params = new URLSearchParams(location.search);
    const filter = params.get("filter");
    const inFilterMode = !!filter && VALID_TOURNAMENTS.includes(filter);

    if (inFilterMode && filter) {
      // フィルターモード：#current-mode は隠し、#player-grid だけ表示
      if (tabContainer) tabContainer.hidden = true;
      if (filterBanner) filterBanner.hidden = false;
      if (currentMode) currentMode.hidden = true;
      if (grid) grid.hidden = false;
      if (filterTitle)
        filterTitle.textContent = `${TOURNAMENT_LABEL[filter]}大会 出場メンバー`;
      let visible = 0;
      items.forEach((li) => {
        const ts = tournamentsOf(li);
        const show = ts.includes(filter);
        li.hidden = !show;
        if (show) visible++;
      });
      if (filterCount) filterCount.textContent = String(visible);
      if (empty) empty.hidden = visible !== 0;
    } else {
      // タブモード
      if (tabContainer) tabContainer.hidden = false;
      if (filterBanner) filterBanner.hidden = true;
      if (currentToolbar) currentToolbar.hidden = currentTab !== "current";
      if (pastToolbar) pastToolbar.hidden = currentTab !== "past";

      if (currentTab === "current") {
        // 現メンバーモード：独立した #current-mode（2セクション）を表示、#player-grid は隠す
        if (currentMode) currentMode.hidden = false;
        if (grid) grid.hidden = true;
        if (empty) empty.hidden = true;
      } else {
        // 歴代モード：#player-grid から data-membership=past のものだけ表示
        if (currentMode) currentMode.hidden = true;
        if (grid) grid.hidden = false;
        let visible = 0;
        items.forEach((li) => {
          const show = li.dataset.membership === "past";
          li.hidden = !show;
          if (show) visible++;
        });
        if (empty) empty.hidden = visible !== 0;
      }
    }
  }

  // タブ切り替え
  tabBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      tabBtns.forEach((b) =>
        b.setAttribute("aria-selected", String(b === btn)),
      );
      currentTab = (btn.dataset.tab as "current" | "past") ?? "current";
      apply();
    });
  });

  // 大会フィルター（歴代タブのチップ）
  // 大会名チップ → URL ?filter=xxx でフィルターモードに遷移し、
  // 現メンバー・歴代・スタッフを横断したその大会の全関係者を表示する。
  // 「すべて」チップ → 通常のタブモードへ戻す。
  filterBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      const f = btn.dataset.filter ?? "all";
      if (f === "all" || !VALID_TOURNAMENTS.includes(f)) {
        filterBtns.forEach((b) =>
          b.setAttribute("aria-pressed", String(b === btn)),
        );
        if (location.search) {
          history.pushState({}, "", "/players");
        }
        apply();
      } else {
        savedTabBeforeFilter = currentTab;
        history.pushState({}, "", `/players?filter=${f}`);
        apply();
      }
    });
  });

  // フィルター解除：URL からクエリを外し、フィルター開始時のタブへ戻す
  if (filterClear) {
    filterClear.addEventListener("click", () => {
      if (savedTabBeforeFilter) {
        currentTab = savedTabBeforeFilter;
        tabBtns.forEach((b) =>
          b.setAttribute(
            "aria-selected",
            String(b.dataset.tab === currentTab),
          ),
        );
        if (currentTab === "past") {
          filterBtns.forEach((b) =>
            b.setAttribute(
              "aria-pressed",
              String((b.dataset.filter ?? "all") === "all"),
            ),
          );
        }
        savedTabBeforeFilter = null;
      }
      history.pushState({}, "", "/players");
      apply();
    });
  }

  // 戻る／進むに反応
  window.addEventListener("popstate", apply);

  // 初期適用
  apply();
</script>
